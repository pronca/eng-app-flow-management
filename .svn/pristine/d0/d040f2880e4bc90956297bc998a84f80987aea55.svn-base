<div class="background">
<mat-card class="version-card">
<div class="eng-classic-form">
    <h3 *ngIf="isEditModeEdit()" fxFlex="100">{{'EDIT' | translate}}</h3>
    <h3 *ngIf="isEditModeInsert()" fxFlex="100">{{'INSERT' | translate}}</h3>

    <eng-text-field  fxFlex='40'
                     required="true"
                     maxlength="100"
                     label='VR_LABEL_VERSION'
                     property="version">
    </eng-text-field>

    <eng-text-field  fxFlex='40'
                     [style.padding-bottom]="'25px'"
                     required="true"
                     maxlength="100"
                     label='VR_LABEL_DESCRIPTION'
                     property="description">
    </eng-text-field>

    <eng-date-field
            fxFlex='40'
    label='VR_LABEL_START_DATE'
    property="startDate"
    >
    </eng-date-field>

    <eng-date-field
            fxFlex='40'
            label='VR_LABEL_END_DATE'
            property="endDate"
    >
    </eng-date-field>

    <eng-date-field
            fxFlex='40'
            label='VR_LABEL_CREATION_DATE'
            property="creationDate"
            [defaultValue] = data
    >
    </eng-date-field>

</div>
</mat-card>
</div>
