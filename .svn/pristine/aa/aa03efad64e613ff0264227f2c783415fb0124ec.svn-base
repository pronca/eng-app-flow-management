
.filtri {
  background: white;
  margin-bottom: 15px;
  box-shadow: 0px 3px 3px -2px rgba(0, 0, 0, 0.2),
  0px 3px 4px 0px rgba(0, 0, 0, 0.14),
  0px 1px 8px 0px rgba(0, 0, 0, 0.12);
  color: #004545;
}

// .button-green{
//   color: white;
//   background-color: #007575;
// }

.flow-extract-field .mat-form-field {
  width: auto;
  padding-right: 1%;
}

.mat-expansion-panel{
  margin: 8px;
}

.dettaglio{
  margin-bottom: 15px !important;
}

:host ::ng-deep .mat-cell{
  cursor: pointer;
}

:host ::ng-deep .example-container {
  overflow-x: scroll;
  // overflow-y: scroll;
  // max-height: 560px;
  // min-width: 800px;  
  background-color: #fafafa;
}

tr.mat-row{
  text-align: center;
  cursor: pointer;
}

:host ::ng-deep .mat-row.selected{
  background-color: #d8e1e5;
}

:host ::ng-deep tr.mat-row:hover{
  background-color: #d8e1e5;  
}

:host ::ng-deep th.mat-header-cell{
  text-align: center;
  white-space:nowrap;
  background-color: #dcdcdc;
}

:host ::ng-deep .mat-table {
  width: 100%;
}

:host ::ng-deep  .mat-paginator-outer-container {
  display: flex;
  background-color: #fafafa;
}

.background {
  background-color: #fafafa;
  overflow-x: hidden;
}

::ng-deep .mat-horizontal-stepper-header-container {
  white-space: nowrap;
  display: flex;
  align-items: center;
  background-color: #fafafa;
}

:host ::ng-deep .mat-horizontal-content-container {
  overflow: hidden;
  background-color: #fafafa;
  padding: 0 0 0 0;
}

::ng-deep .activity-element {
  margin: 0px;
  flex: 1;
  position: absolute;
  top: 0px;
  bottom: 0px;
  right: 0px;
  left: 0px;
  background-color: #fafafa;
}

.mat-chip{
  background-color: #E0E0E0;
  margin-bottom: 5px;
}

:host ::ng-deep  .mat-chip-list-wrapper {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  margin: -4px;
  padding-bottom: 10px;
}

:host ::ng-deep .mat-paginator-container {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 56px;
  padding: 0 8px;
  flex-wrap: wrap-reverse;
  width: auto;
  margin: auto;
}

.form-campo{
  width: 50%;
  padding: 5px;
}

.toolbarBottom{
  bottom: 0;
  position: fixed; 
  width: 100%; 
  // bottom: -150px;
  // position:absolute;
  //  width:98%;
}

.paginatorToolbar{
  color: #fafafa;
  text-decoration:  #007575;
}

td.mat-cell:first-of-type, td.mat-footer-cell:first-of-type,  
th.mat-header-cell:first-of-type {
   padding-left: 0px;
   padding-right: 0px;
}

.paginator{
  position: fixed;
  bottom: 0;
  width: 100%;
}

.prova{
  cursor: unset !important;
}

.prova:hover{
  background-color: white !important;  
}

.provaCell{
  background:  #eceff1;
}  

.provaHeader{
  background: #cfd8dc !important;
}

tr.example-detail-row {
  height: 0;
  cursor: unset;
}

tr.example-detail-row:hover {
  background-color: white;  
  cursor: unset;
}

.example-element-row td {
  border-bottom-width: 0;
}

.example-element-detail {
  overflow: hidden;
}

:host ::ng-deep th.mat-header-cell{
  text-align: center;
  white-space:nowrap;
  background-color: #fafafa;
  font-weight: bold;
  color: #007575;
  font-size: 15px;
}



.mask {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 100%;
  z-index: 500;
  background-color: rgba(0,0,0,0.7)
}
.lds-roller {
  top:50%;
  left:50%;
  display: inline-block;
  position: fixed;
  width: 64px;
  height: 64px;
}
.lds-roller div {
  animation: lds-roller 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
  transform-origin: 32px 32px;
  
}
.lds-roller div:after {
  content: " ";
  display: block;
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #ffff;
  margin: -3px 0 0 -3px;
  z-index: 10;
}
.lds-roller div:nth-child(1) {
  animation-delay: -0.036s;
}
.lds-roller div:nth-child(1):after {
  top: 50px;
  left: 50px;
}
.lds-roller div:nth-child(2) {
  animation-delay: -0.072s;
}
.lds-roller div:nth-child(2):after {
  top: 54px;
  left: 45px;
}
.lds-roller div:nth-child(3) {
  animation-delay: -0.108s;
}
.lds-roller div:nth-child(3):after {
  top: 57px;
  left: 39px;
}
.lds-roller div:nth-child(4) {
  animation-delay: -0.144s;
}
.lds-roller div:nth-child(4):after {
  top: 58px;
  left: 32px;
}
.lds-roller div:nth-child(5) {
  animation-delay: -0.18s;
}
.lds-roller div:nth-child(5):after {
  top: 57px;
  left: 25px;
}
.lds-roller div:nth-child(6) {
  animation-delay: -0.216s;
}
.lds-roller div:nth-child(6):after {
  top: 54px;
  left: 19px;
}
.lds-roller div:nth-child(7) {
  animation-delay: -0.252s;
}
.lds-roller div:nth-child(7):after {
  top: 50px;
  left: 14px;
}
.lds-roller div:nth-child(8) {
  animation-delay: -0.288s;
}
.lds-roller div:nth-child(8):after {
  top: 45px;
  left: 10px;
}
