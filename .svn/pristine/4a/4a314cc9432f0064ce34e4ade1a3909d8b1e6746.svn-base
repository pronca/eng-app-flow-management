  serachDashY($event) {
    this.valueFilterYear = $event;
    var date = new Date();
    if (this.valueFilterYear != date.getFullYear() || this.valueFilterMonth != (date.getMonth() + 1)) {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = false;
      this.visibleOld = true;

    } else {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = true;
      this.visibleOld = false;
    }

    this.getAll();
  }

  serachDashM($event) {

    this.valueFilterMonth = $event;
    var date = new Date();
    if (this.valueFilterMonth != (date.getMonth() + 1) || this.valueFilterYear != date.getFullYear()) {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = false;
      this.visibleOld = true;
      this.getRegionBadge();

    } else {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = true;
      this.visibleOld = false;
      this.getAll();

    }


  }


  downloadXLSXCheck(tipo: String){
    if(!this.download_){
      this.exportFileXLSX(tipo);
    }
    else{
      this.activityManager.engApplication.notifyMessage('Download File XLS in corso, attendere il completamento');
    }
  }



  exportFileXLSX(tipo: String) {
    this.download_ = true;
    this.header.visible = true;
    this.header.label = "Donwloading XLS";

    this.activityManager.getCurrentPage().setPageMainObject(this.header);

    this.flowConfigurationService.downloadFlowErrorXlsx(this.fmflow, this.valueFilterMonth, this.valueFilterYear, tipo).then(result => {
      if (result.size > 0) {
        var file = new Blob([result], { type: 'application/zip' });
        var fileURL = URL.createObjectURL(file);
        var anchor = document.createElement("a");
        anchor.download = "Pratiche errate flusso " + this.fmflow.name; 
        anchor.href = fileURL;
        anchor.click();
        // window.open(fileURL);

        this.header.visible = false;
        this.header.label = "";
        this.activityManager.getCurrentPage().setPageMainObject(this.header);
        this.download_ = false;

      } else {
        this.activityManager.engApplication.notifyMessage('Nessun file presente');
        this.download_ = false;
      }
    });

  }

  getDynamicBadge() {




    let tipo = "AZIENDALE";

    this.flowConfigurationService.getDashboardConfig(this.fmflow.id, tipo)
      .then(result => {
        if (result.success) {

          this.elementDashboard = result.opTargetObject.items;
          this.getDashboard();

        }
        else {
          this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento dei badge dinamici');
        }
      });

  }






  getRegionBadge() {


    let tipo = "REGIONALE";

    this.flowConfigurationService.getDashboardConfig(this.fmflow.id, tipo)
      .then(result => {
        if (result.success) {

          this.elementRegionDashboard = result.opTargetObject.items;
          // this.getRegionValues();
          this.getAll();

        }
        else {
          this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento dei badge regionali');
        }
      });

  }


  calculatePercent() {
    //this.percentDate = [];

    if (this.scartoAnagraficheValue == 0 || Number(this.ricaviTotaliValue) == 0) {

      this.percentDate.push(" ");

    } else {
      let percentAnag = Math.round((this.scartoAnagraficheValue) / Number(this.ricaviTotaliValue) * 100);
      this.percentDate.push(" rispetto ai ricavi: " + percentAnag + "%");
    }
    if (this.scartoDatiCliniciValue == 0 || Number(this.ricaviTotaliValue) == 0) {
      this.percentDate.push(" ");
    } else {
      let percentClinic = Math.round((this.scartoDatiCliniciValue) / Number(this.ricaviTotaliValue) * 100);
      this.percentDate.push(" rispetto ai ricavi: " + percentClinic + "%");
    }

  }

  isEditModeEdit(){
    return false;
}

  pushDescription(desc: any): any[]{
    let descArray: any[] = [];
    descArray[0] = "";
    let length = desc.length;
    let p = 40;
    let k = 0;
    let q = 0;
    let found: boolean = false;
    while(!found){
      let l = (length - k)/p;
      if(l>1){
        let space: boolean = false;
        q = k;
        while(!space){
          if(desc[p+q] == " "){
            let str = desc.substring(k,p+q);
            str += "\n"
            k = q+p;
            descArray[0] += str;
            space = true;
          }
          else{
            q = q -1;
            if((p+q)<=k){
              let str = desc.substring(k,p+(k-1));
              str += "_\n";
              q=k;
              k=p+(k-1);
              descArray[0] += str;
              space = true;
            }
          }
        }
      }else{
        let str = desc.substring(k,length);
        descArray[0] += str;
        found = true;
      }
    }
    return descArray;
  }
  
refreshMask(){
  this.getAll();
}

onResume(){
  this.getAll();
}

 //Dragover listener
 @HostListener('dragover', ['$event']) onDragOver(evt) {
  evt.preventDefault();
  evt.stopPropagation();
  // this.background = '#9ecbec';
  this.opacity = '0.8'
}

//Dragleave listener
@HostListener('dragleave', ['$event'])
public onDragLeave(evt) {
  evt.preventDefault();
  evt.stopPropagation();
  //this.background = '#f5fcff'
  this.opacity = '1'
}

//Drop listener
@HostListener('drop', ['$event'])
public ondrop(evt) {
  evt.preventDefault();
  evt.stopPropagation();
  //this.background = '#f5fcff'
  this.opacity = '1'
  let files = evt.dataTransfer.files;
  if (files.length > 0) {
      this.onFileDropped.emit(files)
  }
}

allowDrop(ev) {
  ev.preventDefault();
}

uploadReturns(el, year: any) {
  let inputFile = el.files[0];
  el.value = '';
  this.readFile(inputFile).then((file) => {

      this.file = [file];
      this.files = [file.name];

      let successMessage: string = this.activityManager.engApplication.i18nInstant('!i18n# File caricato');
      this.activityManager.engApplication.notifyMessage(successMessage);

      // let el: HTMLElement = document.getElementById('uploadReturnsInput');
      // el.nodeValue = undefined;

      this.saveFile(file, year);
  });
}

readFile(inputFile: any): Promise<{
  name: string;
  size: number;
  type: string;
  content: any
}> {
  let deferred = Promises.defer<any>()
  var reader = new FileReader();
  reader.onload = (onLoadEvent) => {
      var arrayBuffer = onLoadEvent.target['result'];
      console.log("on Load ", onLoadEvent);
      deferred.resolve({
          name: inputFile.name,
          size: inputFile.size,
          type: inputFile.type,
          content: arrayBuffer
      });
  };
  reader.onprogress = (progressEvent) => {
      console.log("onprogress ", progressEvent)
  };
  reader.readAsArrayBuffer(inputFile);
  return deferred.promise;
}

saveFile(file: any, year: any){
  this.header.visible = true;
  this.header.label = "Upload file in corso..";
  this.activityManager.getCurrentPage().setPageMainObject(this.header);

  this.flowConfigurationService.saveReturnsFilesTot(file,this.fmflow.id,this.version, year.toString()).then(response => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);

      let result: any = response.opTargetObject;
      if (result.success) {
          let successMessage: string = this.activityManager.engApplication.i18nInstant('!i18n# Upload avvenuto con successo');
          this.activityManager.engApplication.notifyMessage(successMessage);
      } else {
          this.choices = [];
          this.choices.push(this.choice);
          this.activity.getUserConfirmService().askChooseOneMessage(this.choices, 'Attenzione', result.message)
              .then(function () {
                      return;
                  }
              );
      }
  }).catch((e) => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);

      let errorMessage: string = this.activityManager.engApplication.i18nInstant('!i18n# Errore Inaspettato');
      this.activityManager.engApplication.notifyMessage(errorMessage);
  });
  // return Promise.resolve();
}


}
