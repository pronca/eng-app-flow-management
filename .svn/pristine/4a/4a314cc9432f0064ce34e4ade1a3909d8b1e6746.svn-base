  date = new FormControl(moment());




  errorView(psAction: String, $event): void {

    let startingParams: any = {};
    startingParams.editItem = this.fmflow;
    startingParams.editItem.extra = false;
    if(this.valueFilterMonth<10){
      startingParams.extraMonth = "0" + this.valueFilterMonth;
    }else{
      startingParams.extraMonth = this.valueFilterMonth;
    }
    startingParams.extraYear = this.valueFilterYear;
    startingParams.region = undefined;
    this.activityManager.getCurrentPage().setPageMainObject(startingParams);
    this.activityManager.startChildActivityByName("flow-error.edit", startingParams);
  }

