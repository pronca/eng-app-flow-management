  genericMethod(element: any, $event): void {

    let starterParams: any = this.activity.startingParams;
    starterParams.editItem = this.fmflow;
    // starterParams.editItem.region2 = false;

    if(this.valueFilterMonth<10){
      starterParams.extraMonth = "0" + this.valueFilterMonth;
    }else{
      starterParams.extraMonth = this.valueFilterMonth;
    }
    starterParams.extraYear = this.valueFilterYear;

    if (element.name == "PRATICHE_NOT_SEND_REG") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "pratiche_tot";
      this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    }else if(element.name == "PRATICHE_REG") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "pratiche_tot";
      this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    }else if(element.name == "PRATICHE_RIC_REG") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "pratiche_tot";
      this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    }else if(element.name == "PRATICHE_ERRATE_REG") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "pratiche_error";
      this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    }else if(element.name == "ERRORI_REG") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "error_reg";
      this.activityManager.startChildActivityByName("flow-error.edit", starterParams);
    }else if(element.name == "SEGNALAZIONI_REG") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "segnalazioni_reg";
      this.activityManager.startChildActivityByName("flow-error.edit", starterParams);
    }else if(element.name == "PRATICHE_SEGNALAZIONI_REG") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "pratiche_error";
      this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    }else if(element.name == "WARNING") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "error_reg";
      this.activityManager.startChildActivityByName("flow-error.edit", starterParams);
    }else if(element.name == "PRATICHE_WARNING") {
      starterParams.region = element.name;
      starterParams.editItem.extra = "pratiche_error";
      this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    }

    // if (element.activity == "PRATICHE") {
    //   starterParams.editItem.region = true;
    //   starterParams.editItem.extra = "pratiche_tot";
    //   if (element.name == "PRATICHE_RIC_REG") {
    //     starterParams.editItem.region2 = true;
    //     this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    //   } else {
    //     this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    //   }
    // }
    // if (element.activity == "PRATICHE_ERR") {
    //   starterParams.editItem.region = true;
    //   starterParams.editItem.extra = "pratiche_error";
    //   this.activityManager.startChildActivityByName("pratica-flow.edit", starterParams);
    // }
    // if (element.activity == "ERRORI") {
    //   starterParams.editItem.region = true;
    //   this.activityManager.startChildActivityByName("flow-error.edit", starterParams);
    // }

  }


  getDashboard(): void {


    this.ricaviTotaliValue = "0";
    this.praticheErrorsValue = "0";
    this.errorsValue = "0";
    this.praticheValue = "0";
    this.maxAnaCli = 0;
    //   this.scartoAnagraficheValue = "0";
    // this.scartoDatiCliniciValue = "0";
    this.flowConfigurationService.getDashboardByFlow(this.fmflow.code, this.valueFilterMonth, this.valueFilterYear)
      .then(result => {
        if (result.success) {

          this.dashboard = result.opTargetObject.items;

          let myMoment = moment(this.dashboard[0].lastUpdate);
          this.requestDate = myMoment.format('D MMM YYYY HH:mm');

          for (let i = 0; i < this.dashboard.length; i++) {
            if (this.dashboard[i].widgetName == "PRATICHE") {
              this.praticheLabel = this.dashboard[i].label;
              this.praticheValue = this.dashboard[i].value;
              this.praticheTooltip = this.dashboard[i].tooltip;
            }
            if (this.dashboard[i].widgetName == "ERRORI") {
              this.errorsLabel = this.dashboard[i].label;
              this.errorsValue = this.dashboard[i].value;
              this.errorsTooltip = this.dashboard[i].tooltip;
            }
            if (this.dashboard[i].widgetName == "PRATICHE_ERRATE") {
              this.praticheErrorsLabel = this.dashboard[i].label;
              this.praticheErrorsValue = this.dashboard[i].value;
              this.praticheErrorsTooltip = this.dashboard[i].tooltip;
            }
            if (this.dashboard[i].widgetName == "ANAGRAFICHE_ERRATE") {
              this.anagraficheErrorsLabel = this.dashboard[i].label;
              this.anagraficheErrorsValue = Number(this.dashboard[i].value);
            }
            if (this.dashboard[i].widgetName == "DATI_CLINICI_ERRATI") {
              this.datiCliniciErrorsLabel = this.dashboard[i].label;
              this.datiCliniciErrorsValue = Number(this.dashboard[i].value);
            }
            if (this.dashboard[i].widgetName == "RICAVI_TOTALI") {
              this.ricaviTotaliLabel = this.dashboard[i].label;
              this.ricaviTotaliValue = this.dashboard[i].value;
            }
            if (this.dashboard[i].widgetName == "SCARTO_DATI_CLINICI") {
              this.scartoDatiCliniciLabel = this.dashboard[i].label;
              this.scartoDatiCliniciValue = Number(this.dashboard[i].value);
              this.lineChartData.push(this.scartoDatiCliniciValue);

            }
            if (this.dashboard[i].widgetName == "SCARTO_ANAGRAFICHE") {
              this.scartoAnagraficheLabel = this.dashboard[i].label;
              this.scartoAnagraficheValue = Number(this.dashboard[i].value);
              this.lineChartData.push(this.scartoAnagraficheValue);

              let myMoment = moment(this.dashboard[i].lastUpdate);
              this.lastUpdateScarto = myMoment.format('D MMM YYYY HH:mm');

            }

            for (let j = 0; j < this.elementDashboard.length; j++) {
              if (this.dashboard[i].widgetName == this.elementDashboard[j].name) {
                this.elementDashboard[j].value = this.dashboard[i].value;
              }
            }

            for (let j = 0; j < this.elementRegionDashboard.length; j++) {
              if (this.dashboard[i].widgetName == this.elementRegionDashboard[j].name) {
                this.elementRegionDashboard[j].value = this.dashboard[i].value;
              }
            }

          }

          this.visibleScarto = true;
          this.calculatePercent();

        } else {
          this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento delle dashboard');
        }
      })
      .catch(e => {
        this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento delle dashboard');
      }
      );
  }





  getDashboardForPratiche(): void {

    this.flowConfigurationService.getDashboardProcedureByFlow(this.fmflow.name)
      .then(result => {
        if (result.success) {
          this.dashboardPratiche = result.opTargetObject.items;

          this.lineChartData2.push(this.dashboardPratiche[0].day7);
          this.lineChartData2.push(this.dashboardPratiche[0].day6);
          this.lineChartData2.push(this.dashboardPratiche[0].day5);
          this.lineChartData2.push(this.dashboardPratiche[0].day4);
          this.lineChartData2.push(this.dashboardPratiche[0].day3);
          this.lineChartData2.push(this.dashboardPratiche[0].day2);
          this.lineChartData2.push(this.dashboardPratiche[0].day1);

          for (let i = 6; i >= 0; i--) {
            this.lineChartLabels2.push(moment(this.dashboardPratiche[0].lastUpdate).subtract(i, 'd').format('DD/MM'));
          }
          this.dateToPratiche = moment(this.dashboardPratiche[0].lastUpdate).format('DD/MM');


          this.visiblePratiche = true;


        } else {
          this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento del grafico pratiche');
        }
      })
      .catch(e => {
        this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento del grafico pratiche');
      }
      );
  }


  getDashboardForErrors(): void {

    this.errorLabelList = [];
    this.maxSizeError = [];


    this.flowConfigurationService.getDashboardErrorsByFlow(this.fmflow.name, this.valueFilterMonth, this.valueFilterYear)
      .then(result => {
        if (result.success) {
          this.dashboardErrors = result.opTargetObject.items;
          if (this.dashboardErrors != null) {
            let myMoment = moment(this.dashboardErrors[0].lastUpdate);
            this.requestErrorDate = myMoment.format('D MMM YYYY HH:mm');


            for (let i = 0; i < this.dashboardErrors.length; i++) {
              this.maxSizeError.push(this.dashboardErrors[i].countError);
              this.lineChartData3.push(this.dashboardErrors[i].countError);
              this.errorLabelList.push("Errore" + i);
              this.customDesc.push(this.pushDescription(this.dashboardErrors[i].description));
              // this.customDesc.push(this.dashboardErrors[i].description);
            }
            this.maxError = Math.max.apply(null, this.maxSizeError);
            this.maxError = this.maxError + ((this.maxError / 100) * 10);

            this.lineChartLabels3 = this.errorLabelList;

            this.visibleError = true;

          }
        } else {
          this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento del grafico top5errori');
        }
      })


