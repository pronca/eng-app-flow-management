.row-filter{
  height: 9%;
  width: 100%;
  background-color: #fafafa;
}

.form-input-div{
  height: inherit;
  background-color: #fafafa;
}

::ng-deep mat-dialog-content.mat-form-field   {
  background-color: #fafafa;
  width: 100%;
  margin: auto;
  align-items: center;
}



.mat-dig-content{
  width: 90%;
  margin: auto;
  padding-top: 15px;
}

.mat-dialog-actions {
  margin-left: 13px;
}

mat-label {
  font-size: 12pt; 
}
mat-option{
  font-size: 12pt;
}

.select-mat-option{
  font-size: 12pt;
}

::ng-deep .placeholder{
  font-size: 12pt;
}

mat-form-field {
  margin-left: 5px;
}

mat-sort-header-container mat-sort-header-button{
  font-size: 15px;
}

table.mat-table  { 
  width: 98%;
  margin: auto; 
  overflow-x: scroll; 
}

mat-cell{
  word-wrap: break-word;
}

.as-table-cognome .as-table-nome{
  width: 12%;
}

.as-buttons{
  width: 100%;
  margin: auto;

}

.as-buttons button{
  width: 45%;
  text-align: center;
  margin: auto;
}

.toolbarBottom{
  bottom: 0;
  position: fixed;
  text-align: center
}

.uploadToolbar{
  width: 95%;
  margin: auto;
 
}

.file-input {
  display: none;   
}

.file-upload{
  width: 95%;
  height: 100%;
  display: flex;
  justify-content:space-between;
}

.uploadToolbar{
  padding: 10px;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 100%;
  z-index: 500;
  background-color: rgba(0,0,0,0.7)
}

.lds-roller {
  top:50%;
  left:50%;
  display: inline-block;
  position: fixed;
  width: 64px;
  height: 64px;
}
.lds-roller div {
  animation: lds-roller 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
  transform-origin: 32px 32px;
  
}
.lds-roller div:after {
  content: " ";
  display: block;
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #ffff;
  margin: -3px 0 0 -3px;
  z-index: 10;
}
.lds-roller div:nth-child(1) {
  animation-delay: -0.036s;
}
.lds-roller div:nth-child(1):after {
  top: 50px;
  left: 50px;
}
.lds-roller div:nth-child(2) {
  animation-delay: -0.072s;
}
.lds-roller div:nth-child(2):after {
  top: 54px;
  left: 45px;
}
.lds-roller div:nth-child(3) {
  animation-delay: -0.108s;
}
.lds-roller div:nth-child(3):after {
  top: 57px;
  left: 39px;
}
.lds-roller div:nth-child(4) {
  animation-delay: -0.144s;
}
.lds-roller div:nth-child(4):after {
  top: 58px;
  left: 32px;
}
.lds-roller div:nth-child(5) {
  animation-delay: -0.18s;
}
.lds-roller div:nth-child(5):after {
  top: 57px;
  left: 25px;
}
.lds-roller div:nth-child(6) {
  animation-delay: -0.216s;
}
.lds-roller div:nth-child(6):after {
  top: 54px;
  left: 19px;
}
.lds-roller div:nth-child(7) {
  animation-delay: -0.252s;
}
.lds-roller div:nth-child(7):after {
  top: 50px;
  left: 14px;
}
.lds-roller div:nth-child(8) {
  animation-delay: -0.288s;
}
.lds-roller div:nth-child(8):after {
  top: 45px;
  left: 10px;
}
@keyframes lds-roller {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}







  
  