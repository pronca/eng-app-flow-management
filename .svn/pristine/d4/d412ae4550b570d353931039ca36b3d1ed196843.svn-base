                                            }
                                        }
                                    }
                                }
                            }
                            if (this.flowExport.flowConfigurationFilters[i].fields[j][k].filterType == "Numeric") {
                                for (let h = 0; h < this.flowExport.flowConfigurationFilterFieldValues.length; h++) {
                                    if (!this.flowExport.flowConfigurationFilters[i].fields[j][k].range) {
                                        if (this.flowExport.flowConfigurationFilterFieldValues[h].filterId == this.flowExport.flowConfigurationFilters[i].fields[j][k].id) {
                                            this.flowExport.flowConfigurationFilters[i].fields[j][k].numFromValue = this.flowExport.flowConfigurationFilterFieldValues[h].numFromValue;
                                        }
                                    } else {
                                        if (this.flowExport.flowConfigurationFilterFieldValues[h].filterId ==
                                            this.flowExport.flowConfigurationFilters[i].fields[j][k].id) {
                                            if (this.flowExport.flowConfigurationFilterFieldValues[h].numToValue == null) {
                                                this.flowExport.flowConfigurationFilters[i].fields[j][k].numFromValue = this.flowExport.flowConfigurationFilterFieldValues[h].numFromValue;
                                            } else {
                                                this.flowExport.flowConfigurationFilters[i].fields[j][k].numToValue = this.flowExport.flowConfigurationFilterFieldValues[h].numToValue;
                                            }
                                        }
                                    }
                                }
                            }
                            // if(this.flowExport.flowConfigurationFilters[i].fields[j][k].filterType == "Multi") {
                            //     let l = 0;
                            //     for (let h = 0; h < this.flowExport.flowConfigurationFilterFieldValues.length; h++) {
                            //         if (this.flowExport.flowConfigurationFilterFieldValues[h].filterId == this.flowExport.flowConfigurationFilters[i].fields[j][k].id) {
                            //             this.flowExport.flowConfigurationFilters[i].fields[j][k].multiValues[l] = this.flowExport.flowConfigurationFilterFieldValues[h].multiValues[l];
                            //         l++;
                            //         }
                            //     }
                            // }
                            // if(this.flowExport.flowConfigurationFilters[i].fields[j][k].filterType == "Multi"){
                            //         for (let h = 0; h < this.flowExport.flowConfigurationFilterFieldValues.length; h++) {
                            //             if(this.flowExport.flowConfigurationFilterFieldValues[h].filterId==this.flowExport.flowConfigurationFilters[i].fields[j][k].id){
                            //                 this.flowExport.flowConfigurationFilters[i].fields[j][k].multiValues = this.flowExport.flowConfigurationFilterFieldValues[h].multiValues;
                            //             }
