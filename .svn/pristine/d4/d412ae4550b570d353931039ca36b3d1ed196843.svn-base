                                    if (!this.flowExport.flowConfigurationFilters[i].fields[j][k].range) {
                                        if (this.flowExport.flowConfigurationFilterFieldValues[h].filterId == this.flowExport.flowConfigurationFilters[i].fields[j][k].id) {
                                            this.flowExport.flowConfigurationFilters[i].fields[j][k].dateFromValue = this.flowExport.flowConfigurationFilterFieldValues[h].dateFromValue;
                                        }
