    choice: Choice = {
        //icon:'done',
        text: 'OK',
        cssClass: '{text-align:center;}'
    };

    coc: FlowConfigurationFilterField = new FlowConfigurationFilterField();

    choices: Choice[] = [];
    checkComboDinamicFilters: boolean = true;
    isStandard: boolean = true;
    isStandard2: boolean = true;
    isDisable: boolean = false;
    isDisableField : boolean = false;
    isDisableVersion: boolean = true;
    isDisableDinamic: boolean = true;
    ckd: boolean = false;
    flowExport: FlowExport = new FlowExport();
    flowConfigurationFilterFields: FlowConfigurationFilterField[] = [];
    flowConfigurationFilterFieldsS: FlowConfigurationFilterField[] = [];
    flowConfigurationFilterFieldsSt: FlowConfigurationFilterField[] = [];
    utils = new Utils();
