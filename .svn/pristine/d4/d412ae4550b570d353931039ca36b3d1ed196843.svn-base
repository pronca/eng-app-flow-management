    type:boolean = true;
    states: StateChips[] = [
        { name: 'Corrette', code: 'CORRETTE', selected: false },
        { name: 'Tutte', code: 'TUTTE', selected: false },
        { name: 'Già Inviate', code: 'GIA_INVIATE', selected: false },
        { name: 'Mai Inviate', code: 'MAI_INVIATE', selected: false },
        { name: 'Corrette Mai Inviate', code: 'MAI_INVIATE,CORRETTE', selected: false }
        ];
    array: StateChips["code"][] = [];
