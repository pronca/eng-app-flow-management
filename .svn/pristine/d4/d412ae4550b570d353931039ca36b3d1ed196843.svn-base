                            if (this.flowExport.flowConfigurationFilters[i].fields[j][k].filterType == "ComboBox"
                                || this.flowExport.flowConfigurationFilters[i].fields[j][k].filterType == "Multi"
                                || this.flowExport.flowConfigurationFilters[i].fields[j][k].filterType == "Radio") {
                                //Prestazioni????
                                this.retriveTabgenFieldValue(this.flowExport.flowConfigurationFilters[i].fields[j][k].filterTable,
                                    this.flowExport.flowConfigurationFilters[i].fields[j][k].filterField, j, k,
