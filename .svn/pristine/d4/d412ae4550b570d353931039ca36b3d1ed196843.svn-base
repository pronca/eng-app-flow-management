    onSelectState(coc: FlowConfigurationFilterField, stato,i){
        stato.selected=!stato.selected;
        this.arrayDynamic = [];

        for (let stat of this.states) {
            if(stato.code == stat.code && stat.selected){
                this.arrayDynamic = [];
                this.arrayDynamic.push(stat.code);
            }else{
                stat.selected = false;
            }
        }

        coc.multiValues = this.arrayDynamic;
        coc.name = "Chips"
        coc.filterType = "Chips"
    }

    drg($event){
        if($event.checked == true){
            this.flowExport.drg = true;
        }else{
            this.flowExport.drg = false;
        }
    }

    standar($event){
        this.isStandard = false;
        if ($event.checked == true) {
            this.mapFlowConfigurationFilters = new Map<string, FlowConfigurationFilter>();
            this.flowConfigurationFilterFieldsSt = [];
            this.flowConfigurationFilterFieldsS = [];
            this.flowConfigurationFilterFields = [];
            this.filters = [];
            //Controllo se JobTalend è stato già caricato
            //if(this.jobTalends == null || this.jobTalends.length==0) {
            this.retrieveJobTalend(this.flow.code, this.version.id);
            //}
            //DISABILITA FILTRI DINAMICI
            this.getConfigurationFilters(this.flow.id, this.version.id, 2, null);
            //this.isDisableDinamic = false;
            // this.schedulingType = this.schedulingTypes[0][0];
            this.flowConfigurationFilterFieldsS.sort(
                (a, b) => (a.position > b.position) ? 1 : ((b.position > a.position) ? -1 : 0));

            this.flowConfigurationFilterFields.sort(
                (a, b) => (a.position > b.position) ? 1 : ((b.position > a.position) ? -1 : 0));

        }
        else{
            this.isStandard = true;
            //this.stringHeader = "";
            this.mapFlowConfigurationFilters = new Map<string, FlowConfigurationFilter>();
            this.flowConfigurationFilterFieldsSt = [];
            this.flowConfigurationFilterFieldsS = [];
            this.flowConfigurationFilterFields = [];
            this.filters = [];
            this.version = this.version;
            //Controllo se JobTalend è stato già caricato
            //if(this.jobTalends == null || this.jobTalends.length==0) {
            this.retrieveJobTalend(this.flow.code, this.version.id);
            //}
            //Controllo se combo filtri dinamici
            if (this.checkComboDinamicFilters) {
                this.setComboDinamicFilters(this.flow.id, this.version.id, 0);
            }
            this.getConfigurationFilters(this.flow.id, this.version.id, 1, null);
            this.isDisableDinamic = false;
            // this.schedulingType = this.schedulingTypes[0][0];
            this.setComboDinamicFilters(this.flow_opt.id, this.version_opt.id, 0);
            //this.ngOnInit();
        }
        this.flowConfigurationFilterFieldsS.sort(
            (a, b) => (a.position > b.position) ? 1 : ((b.position > a.position) ? -1 : 0));

        this.flowConfigurationFilterFields.sort(
            (a, b) => (a.position > b.position) ? 1 : ((b.position > a.position) ? -1 : 0));
    }

    itemTrackBy(index: number, item) {
            return item ? item.filterType : "ComboBox";
    }

    //tk 1240901
    onOptionsSelected(co, event) {
        let value : string = event;
        let nomeCampo : string = co.name;

        for (let i = 0; i < this.flowExport.flowConfigurationFilters.length; i++) {
            for (let j = 0; j < this.flowExport.flowConfigurationFilters[i].fields.length; j++) {
                for (let k = 0; k < this.flowExport.flowConfigurationFilters[i].fields[j].length; k++) {
                    if (this.flowExport.flowConfigurationFilters[i].fields[j][k].filterType == "ComboBox" && this.flowExport.flowConfigurationFilters[i].fields[j][k].name==nomeCampo) {
                        for (let h = 0; h < this.flowExport.flowConfigurationFilterFieldValues.length; h++) {
                            if (this.flowExport.flowConfigurationFilterFieldValues[h].filterId == this.flowExport.flowConfigurationFilters[i].fields[j][k].id) {
                                this.flowExport.flowConfigurationFilters[i].fields[j][k].singleValue = value;
                            }
                        }
                    }
                }
            }
        }
     }

}

