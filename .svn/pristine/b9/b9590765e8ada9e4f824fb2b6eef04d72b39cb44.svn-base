.filtri {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  background: #fafafa;
  padding: 10px 15px;
  width: 100%;
  box-sizing: border-box;
}

.flow-extract-field {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  overflow-x: hidden;
  background-color: #fafafa;
  box-sizing: border-box;
}

.flow-extract-field .mat-form-field {
  flex: 1 1 200px;
  min-width: 150px;
  max-width: 250px;
  box-sizing: border-box;
}

button[mat-button] {
  height: 56px;
  align-self: flex-end;
}

.example-container {
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;          /* nessuna barra orizzontale */
  overflow-y: auto;            /* ✅ riattiva scroll verticale */
  background-color: #fafafa;
  flex-grow: 1;
  box-sizing: border-box;
  padding-bottom: 5px;
}

.flowviewreps {
  width: 100%;
  max-width: 100%;
  overflow-y: auto;            /* ✅ scroll verticale locale */
  max-height: calc(100vh - 240px); /* 🔹 evita che sfori la finestra */
  box-sizing: border-box;
}

table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;          /* fondamentale per adattamento proporzionale */
  box-sizing: border-box;
}

th.mat-header-cell, td.mat-cell {
  text-align: center;
  overflow: hidden;             /* evita sbordi */
  text-overflow: ellipsis;      /* “...” quando il testo è troppo lungo */
  white-space: nowrap;
  padding: 6px 4px;
}

th.mat-header-cell {
  background-color: #fafafa;
  font-weight: 600;
  color: #007575;
  font-size: 12px !important;   /* 🔹 ridotto da 14-15px a 12px */
  line-height: 1.1;
  padding: 4px 2px !important;
  border-bottom: 1px solid #ddd;
  text-align: center;
  white-space: nowrap;
}

th.mat-header-cell:nth-child(1),
td.mat-cell:nth-child(1) { width: 4%; }   /* Checkbox */
th.mat-header-cell:nth-child(2),
td.mat-cell:nth-child(2) { width: 5%; }   /* ID */
th.mat-header-cell:nth-child(3),
td.mat-cell:nth-child(3) { width: 5%; }   /* Tipologia */
th.mat-header-cell:nth-child(4),
td.mat-cell:nth-child(4) { width: 5%; }   /* Utente */
th.mat-header-cell:nth-child(5),
td.mat-cell:nth-child(5) { width: 5%; }  /* Flusso */
th.mat-header-cell:nth-child(6),
td.mat-cell:nth-child(6) { width: 5%; }   /* Versione */
th.mat-header-cell:nth-child(7),
td.mat-cell:nth-child(7) { width: 8%; }   /* Pratiche */
th.mat-header-cell:nth-child(8),
td.mat-cell:nth-child(8) { width: 10%; }   /* Data richiesta */
th.mat-header-cell:nth-child(9),
td.mat-cell:nth-child(9) { width: 10%; }   /* Inizio estrazione */
th.mat-header-cell:nth-child(10),
td.mat-cell:nth-child(10) { width: 10%; }  /* Fine estrazione */
th.mat-header-cell:nth-child(11),
td.mat-cell:nth-child(11) { width: 8%; }  /* Stato richiesta */
th.mat-header-cell:nth-child(12),
td.mat-cell:nth-child(12) { width: 8%; }  /* Stato estrazione */
th.mat-header-cell:nth-child(13),
td.mat-cell:nth-child(13) { width: 8%; }  /* Validazione record */
th.mat-header-cell:nth-child(14),
td.mat-cell:nth-child(14) { width: 8%; }  /* Consolidamento */
th.mat-header-cell:nth-child(15),
td.mat-cell:nth-child(15) { width: 8%; }  /* Validazione regionale */
th.mat-header-cell:nth-child(16),
td.mat-cell:nth-child(16) { width: 6%; }  /* Download */
th.mat-header-cell:nth-child(17),
td.mat-cell:nth-child(17) { width: 5%; }  /* Altro pulsante */

