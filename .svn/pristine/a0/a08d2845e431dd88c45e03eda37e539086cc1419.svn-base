@media screen and (max-height: 619px) {
  .flowviewreps {
    max-height: 61vh;
  }
}

@media screen and (min-height: 620px) and (max-height: 712px) {
  .flowviewreps {
    max-height: 65vh;
  }
}

@media screen and (min-height: 713px) and (max-height: 800px) {
  .flowviewreps {
    max-height: 50vh;
  }
}

@media screen and (min-height: 801px) and (max-height: 860px) {
  .flowviewreps {
    max-height: 55vh
  }
}

@media screen and (min-height: 861px)  {
  .flowviewreps {
    max-height: 62vh
  }
}