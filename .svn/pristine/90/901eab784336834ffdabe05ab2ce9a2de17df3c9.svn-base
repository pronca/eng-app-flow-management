    codAziendaLabel: string = "Codice Azienda";   // default
    showPresidio: boolean = false;
    codPresidioLabel: string = "Codice Presidio";

    constructor(
        private flowConfigurationService: FlowConfigurationService,
        private activityManager: ActivityManager,
        @Inject('SearchActivityComponent') public searchComponent: SearchActivityComponent,
    ){
        super();
    }

    ngOnInit(): void {
      
      this.activity.markDirty = () => { }

        let starterParams: any = this.activity.startingParams;

        if(starterParams.editItem.extra && !starterParams.extra){
          this.filterFlow.importId = starterParams.editItem.extra;
        }
        if(starterParams.drg){
          this.filterFlow.drg = "DRG";
        }
        
        this.fmflow = starterParams.editItem;
        
        if(this.fmflow.code.endsWith("_REG")){
          this.regAcc = true;
        }
        this.filterFlow.firstResult = 0;
        this.firstResultDisplay = this.filterFlow.firstResult + 1;
        this.filterFlow.maxResult = 10;
        this.endPage = this.filterFlow.maxResult;
        this.getVersionName();
        this.filterFlow.field = new Array<FilterFlowField>();
        this.filterFlow.fieldData = new Array<FilterFlowFieldData>();
        // this.filterFlow.param = new Array();
        // this.filterFlow.dateIn = new Array();
        // this.filterFlow.dateOut = new Array();
        this.filterFlow.fkFields = new Array();
        this.filterFlow.fkValues = new Array();
        if(starterParams.extra && Object.keys(starterParams.extra).length > 0){
          this.searchFromPatient(starterParams.extra);
        }else{
          this.ricercaConf();
        }
        this.sezioni = this.fmflow.flowTableList;

        // --- Imposto dinamicamente le etichette delle combo in base alla sezione 0 ---
        const sez0 = this.sezioni[0].flowTableFieldList.map(f => f.description.toLowerCase());

        // LABEL Codice Azienda / Soggetto Erogatore (per Telemedicina)
        if (sez0.map(f => f.toLowerCase()).includes("soggettoerogatore")) {
          this.codAziendaLabel = "Soggetto Erogatore";
        } else {
          this.codAziendaLabel = "Codice Azienda";
        }

        // LABEL + SHOW Codice Presidio
        const presidioField = this.sezioni[0].flowTableFieldList.find(f => f.name.toLowerCase() === "codicepresidio");
        if (presidioField) {
          this.showPresidio = true;
          this.codPresidioLabel = presidioField.descriptionsm || "Codice Presidio";
        } else {
          this.showPresidio = false;
        }

        this.ordinaSezioni(this.sezioni);
        let lenght = undefined;
        let lastPage = false;
        this.contaPratiche(lenght,lastPage);
        this.activity.addActivityAction({
          actionType: ActivityActionType.MAIN,
          name: SearchActivityComponent.NEW_ACTION,
          tooltip: "Valida Record",
          icon: "spellcheck",
          isShow: (activity, activityAction) => !this.emptyTables,
          fn: (activity, action) => {
              this.validaRecord();
          return Promise.resolve(null);                   
          }
        });

        this.activity.addActivityAction({
            actionType: ActivityActionType.MAIN,
            name: SearchActivityComponent.EDIT_ITEM_ACTION,
            tooltip: "Downloads XLSX",
            icon: "get_app",
            isShow: (activity, activityAction) => !this.emptyTables,
            fn: (activity, action) => {
                if(!this.download_){
                  this.exportFileXLSX(this.filterFlow);
                  return Promise.resolve(null);
                }
                else{
                    this.activityManager.engApplication.notifyMessage('Download File XLS in corso, attendere il completamento');
                    return Promise.resolve(null);
                }

            }
        });

        let sys: FlowTableField = new FlowTableField();
        sys.name = "DATE_PROCESSING";
        sys.fieldType = "Date";
        sys.descriptionsm = "Data Ricezione";
        this.fieldSys.push(sys);
        sys = new FlowTableField();
        sys.name = "STATUS_GROUP";
        sys.fieldType = "String";
        sys.descriptionsm = "Stato Validazione Pratica";
        this.fieldSys.push(sys);
        sys = new FlowTableField();
        sys.name = "STATE_RECEVIED_APP";
        sys.fieldType = "String";
        sys.descriptionsm = "Stato Invio Da Verticale";
        this.fieldSys.push(sys);
        sys = new FlowTableField();
        sys.name = "STATE_SEND_REGION";
        sys.descriptionsm = "Stato Invio A Regione";
        sys.fieldType = "String";
        this.fieldSys.push(sys);
        sys = new FlowTableField();
        sys.name = "STATUS_REGION";
        sys.descriptionsm = "Stato Validazione Pratica Regionale";
        sys.fieldType = "String";
        this.fieldSys.push(sys);
        sys = new FlowTableField();
        sys.name = "STATUS";
        sys.descriptionsm = "Stato Validazione Record";
        sys.fieldType = "String";
        this.fieldSys.push(sys);
        //sys = new FlowTableField();
        //sys.name = "IMPORT_TYPE";
        //sys.descriptionsm = "Tipo Importazione";
        //sys.fieldType = "String";
        //this.fieldSys.push(sys);

        // carica dati da backend
        this.loadCodiciAzienda();
        this.loadCodiciPresidio();

      }

      loadCodiciAzienda(): void {
        this.flowConfigurationService.searchCodiciAzienda(this.fmflow)
          .then(result => {
            if (result.success && result.opTargetObject) {
              this.aziendeOptions = result.opTargetObject;
              this.codiceAzienda=null;
            } else {
              this.activityManager.engApplication.notifyMessage('Errore nel caricamento dei codici azienda');
            }
          })
          .catch(() => {
            this.activityManager.engApplication.notifyMessage('Errore di connessione al servizio searchCodiciAzienda');
          });
      }

      loadCodiciPresidio(): void {
        this.flowConfigurationService.searchCodiciPresidio(this.fmflow)
          .then(result => {
            if (result.success && result.opTargetObject) {
              this.presidiOptions = result.opTargetObject;
              this.codicePresidio=null;
            } else {
              this.activityManager.engApplication.notifyMessage('Errore nel caricamento dei codici presidio');
            }
          })
          .catch(() => {
            this.activityManager.engApplication.notifyMessage('Errore di connessione al servizio searchCodiciPresidio');
          });
      }

    protected initFormGroup(): void {
        this.fmflow = new FmFlow();
    
      }

      initActivityActions() {
        super.initActivityActions();
        this.activity.removeActivityAction(EditActivityComponent.SAVE_ACTION);
      }

    ricercaConf(): Promise<any> {

      this.showLoadingIndicator = true;
      this.flag = false;
      this.filterFlow.flow = this.fmflow;
      this.filterFlow.flow.flowTableList.forEach(fieldList => fieldList.flowTableFieldList.sort((a,b) => a. position - b.position));
      this.filterFlow.paginated = true;
      this.filterError.firstResultAcc = 0;
      this.firstResultDisplayAcc = this.filterError.firstResultAcc + 1;
      this.firstResultDisplayReg = this.filterError.firstResultAcc + 1;
      if(this.filterFlow.firstResult<=1){
        this.blockLeft = true;
      }else{
        this.blockLeft = false;
      }
      this.blockRight = false;
      if(this.countPratiche){
        if(this.endPage>=this.countPratiche){
          this.blockRight = true;
        }else{
          this.blockRight = false;
        }
      }

      if(!this.activity.startingParams.extra && this.filterFlow.field.length>0 || this.filterFlow.fieldData.length>0){
        let bool: boolean = true;
        this.contaPratiche(bool);
      }else{
        this.showLoadingIndicator = true;
        this.flowConfigurationService.searchFlowView(this.filterFlow).then(result => {
            if (result. success) {
              this.showLoadingIndicator = false;
              this.fkNameList.length = 0;
              this.pkNameList.length = 0;
               this.map = result.opTargetObject[0];
               let m = this.fmflow.flowTableList[0].name;
               let lenght = this.map[m].length;
               if(lenght== 0){
                  this.emptyTables = true;
                  this.blockRight = true;
                  for(let i = 0; i < this.sezioni.length; i++){
                    this.firstResultSez[i] = 0;
                    this.count[i] = 0;
                    this.blockLeftSez[i] = true;
                    this.blockRightSez[i] = true;
                    this.mapFields[i] = result.opTargetObject[1][this.sezioni[i].name];
                    this.generaColonne(i);
                  }
                  this.colonneAggiunteGrid=true;
                  this.firstResultDisplay = 0;
                  this.endPage = 0;
                  this.dataSource = [];
                  this.showLoadingIndicator = false;
                  this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                 return;
               }
               else if(lenght<10){
                  this.blockRight = true;
               }
               for(let i = 0; i < this.sezioni.length; i++){
                  this.mapFields[i] = result.opTargetObject[1][this.sezioni[i].name];
                  this.generaColonne(i);
                  this.dataSource[i] = new MatTableDataSource<any>(this.generateDatasource(i));
                }
                this.colonneAggiunteGrid=true;
                this.selectText = undefined;
                this.selectedValue = undefined;
                this.dateInTemp = undefined;
                this.dateOutTemp = undefined;
            } else {
                this.showLoadingIndicator = false;
                this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento delle colonne');
            }
          }).catch(() => {
          this.showLoadingIndicator = false;
          this.activityManager.engApplication.notifyMessage('Errore inaspettato');
        });
      }
        return Promise.resolve();
    }

    generaColonne(i: number){
      if (!this.colonneAggiunteGrid) {
        this.colMap[i] = [];
        this.displayedColumns[i] = [];
        this.displayedColumns[i].push('FILTER');
        this.displayedColumns[i].push('ERRORS');
        if(this.regAcc){
          this.displayedColumns[i].push('REG');
        }
  
        let mapField = this.mapFields[i];
        let cols = Object.keys(mapField);
        for(let j=0; j<cols.length; j++){
          let colHeader = new header();
          colHeader.name = cols[j];
          colHeader.description = mapField[cols[j]];
          this.colMap[i].push(colHeader);
          this.displayedColumns[i].push(colHeader.name);
        }
  
        if(i==0){
          let colHeader4 = new header();
          colHeader4.name = "DATE_PROCESSING";
          colHeader4.description = "Data Ricezione";
          this.colMap[i].push(colHeader4);
          this.displayedColumns[i].push(colHeader4.name);
          let colHeader5 = new header();
          colHeader5.name = "STATUS_GROUP";
          colHeader5.description = "Stato Validazione Pratica";
          this.colMap[i].push(colHeader5);
          this.displayedColumns[i].push(colHeader5.name);
          let colHeader6 = new header();
          colHeader6.name = "STATE_RECEVIED_APP";
          colHeader6.description = "Stato Invio Da Verticale";
          this.colMap[i].push(colHeader6);
          this.displayedColumns[i].push(colHeader6.name);
          let colHeader7 = new header();
          colHeader7.name = "STATE_SEND_REGION";
          colHeader7.description = "Stato Invio A Regione";
          this.colMap[i].push(colHeader7);
          this.displayedColumns[i].push(colHeader7.name);
          let colHeader9 = new header();
          colHeader9.name = "STATUS_REGION";
          colHeader9.description = "Stato Validazione Pratica Regionale";
          this.colMap[i].push(colHeader9);
          this.displayedColumns[i].push(colHeader9.name);
        }
        let colHeader8 = new header();
        colHeader8.name = "STATUS";
        colHeader8.description = "Stato Validazione Record";
        this.colMap[i].push(colHeader8);
        this.displayedColumns[i].push(colHeader8.name);
        let colHeader10 = new header();
        colHeader10.name = "IMPORT_TYPE";
        colHeader10.description = "Tipo Importazione";
        this.colMap[i].push(colHeader10);
        this.displayedColumns[i].push(colHeader10.name);

        // Recupero dei campi della tabella corrente
        const fieldList = this.fmflow.flowTableList[i].flowTableFieldList || [];
        const m = fieldList.length;

        // Popola fkNameList
        if (i == 0) {
          this.fkNameList[i] = [];
          for (let n = 0; n < m; n++) {
            if (fieldList[n].pk) {
              this.fkNameList[i].push(fieldList[n].name);
            }
          }
          // Rimuove duplicati
          this.fkNameList[i] = this.fkNameList[i].filter((elem, index, self) => index === self.indexOf(elem));
        } else {
          this.fkNameList[i] = [];
          for (let n = 0; n < m; n++) {
            for (let h = 0; h < this.fmflow.flowTableList[i].listFk.length; h++) {
              if (fieldList[n].id === this.fmflow.flowTableList[i].listFk[h].idFieldTable) {
                this.fkNameList[i].push(fieldList[n].name);
              }
            }
          }
        }

        // 🔹 Popola pkNameList in ordine sequenziale in base a "position"
        this.pkNameList[i] = [];

        const pkFields = fieldList
          .filter(f => f.pk)                               // prendo solo i campi PK
          .sort((a, b) => a.position - b.position);         // ordino per posizione crescente

        pkFields.forEach(f => this.pkNameList[i].push(f.name)); // aggiungo i nomi in ordine
      }
    }

    generateDatasource(i: number):Array<any>{

        let data = new Array();
        let h = 0;
        if(i==0){
          h = this.fmflow.flowTableList[i].flowTableFieldList.length+7;
        }else{
          h = this.fmflow.flowTableList[i].flowTableFieldList.length+2;
        }
        let campiTecnici = 0;
        if(this.regAcc == true){
          campiTecnici = 3;
        }else{
          campiTecnici = 2;
        }
        let m = this.fmflow.flowTableList[i].name;
        let lenght = this.map[m].length;
        this.totalRecord[i] = lenght;
        let columnValue = null;
          for(let z = 0; z < lenght; z++){
            data[z] = {};
            for (let j = 0; j < h; j++) {
              if(h == 1){
                columnValue = this.map[m][j];
              }else{
               columnValue = this.map[m][z][j];
              }
              let columnName = this.displayedColumns[i][j+campiTecnici];
              if(this.isDate(columnValue)){
                columnValue = this.dateConvert(columnValue);
              }
              data[z][columnName] = columnValue;
            }
          }
          if(i>0){
            this.blockLeftSez[i] = true;
            this.firstResultSez[i] = 1;
            if(data.length<=10){
              this.count[i] = data.length;
              this.blockRightSez[i] = true;
            }else{
              this.blockRightSez[i] = false;
              this.count[i] = 10;
              this.dataApp[i] = new Array();
              this.dataApp[i] = data;
              data = data.slice(0,10);
            }
          }
          else{
            if(data.length == 0){
              this.endPage  = 0;
            }else{
              this.endPage = data.length + this.filterFlow.firstResult;
              this.firstResultDisplay = this.filterFlow.firstResult + 1;
              //gestisco il caso in cui ci troviamo all'ultima pagina in cui sono presenti 10 record e quindi devo disattivare l'avanzamento a dx
              if (this.blockRight==false) {
                if(this.endPage>=this.countPratiche){
                  this.blockRight = true;
                } 
              }
            }
          }
          
      return data;
  }

  getVersionName(): void{

    this.flowConfigurationService.getVersionNameById(this.fmflow)
    .then(result => {
        if (result.success) {
           this.version = result.opTargetObject;
           this.activity.title = "!i18n#" + this.fmflow.name + " " + this.version;
        } else {
            this.activityManager.engApplication.notifyMessage('Errore in fase di ricezione della versione');
        }
    })
    .catch(e => {
      this.activityManager.engApplication.notifyMessage('Errore in fase di ricezione della versione');
    }
    ); 
  }

  changeStep($event){
    let evento = $event;
    this.iToolbar = evento;

    this.selectedSection = evento.selectedIndex;

    if (this.validate = true) {
      this.activity.removeActivityAction(SearchActivityComponent.NEW_ACTION);
      this.validate = false;
    }

    if (evento.selectedIndex == 0) {
      if(!this.emptyTables){
        this.firstResultDisplay = this.filterFlow.firstResult + 1;
        //gestisco il caso in cui ci troviamo all'ultima pagina in cui sono presenti 10 record e quindi devo disattivare l'avanzamento a dx
        if(this.endPage>=this.countPratiche){
          this.blockRight = true;
        } else {
          this.blockRight = false;
        }
        if(this.firstResultDisplay > 1){
          this.blockLeft = false;
        }else{
          this.blockLeft = true;
        }
      }

      this.activity.addActivityAction({
        actionType: ActivityActionType.MAIN,
        name: SearchActivityComponent.NEW_ACTION,
        tooltip: "Valida Record",
        icon: "spellcheck",
        fn: (activity, action) => {
            this.validaRecord();
        return Promise.resolve(null);                   
        }
      });

        this.validate = true;

    }
  }

  isDate(value) {
    return value instanceof Date;
  }

  dateConvert(date): string {
    return this.leftpad(date.getDate())
              + '/' + this.leftpad(date.getMonth() + 1, 2)
              + '/' + this.leftpad(date.getFullYear(), 4)
              ;
  }

  dateHConvert(data): string {
    if (data != null) {
        let myMoment = moment(data);
        return myMoment.format('D/MM/YYYY HH:mm:ss');
    } else
        return "";
  }
  
  leftpad(val, resultLength = 2, leftpadChar = '0'): string {
    return (String(leftpadChar).repeat(resultLength)
          + String(val)).slice(String(val).length);
  }

  getServerDataLeft(i: number){
    if(this.filterFlow.firstResult>0 && this.selectedSection == 0){
      this.filterFlow.firstResult = this.filterFlow.firstResult - 10;
      this.endPage = this.filterFlow.firstResult + 10;
      this.firstResultDisplay = this.filterFlow.firstResult + 1;
      this.ricercaConf();
    }else if(this.selectedSection >0){
      if(!this.blockLeftSez[i]){
        this.blockRightSez[i] = false;
        this.firstResultSez[i]=this.firstResultSez[i]-10;
        this.count[i] = this.firstResultSez[i]+9;
        this.dataSource[i] = new MatTableDataSource<any>(this.dataApp[i].slice(this.firstResultSez[i], this.count[i]));
        if( this.firstResultSez[i]<=1){
          this.blockLeftSez[i] = true;
        }
      }
    }
  }

  getServerDataRight(i:number){
      if(this.selectedSection >0){
        if(!this.blockRightSez[i]){
          this.blockLeftSez[i] = false;
          this.firstResultSez[i]=this.count[i]+1;
          if(this.count[i]+10 < this.dataApp[i].length){
            this.count[i] = this.firstResultSez[i] + 9;
            this.blockRightSez[i] = false;
          }else{
            this.count[i] = this.dataApp[i].length;
            this.blockRightSez[i] = true;
          }
          this.dataSource[i] = new MatTableDataSource<any>(this.dataApp[i].slice(this.firstResultSez[i]-1, this.count[i]));
        }
      }else{
        if(!this.blockRight){
          this.filterFlow.firstResult = this.filterFlow.firstResult + 10;
          this.ricercaConf();
        }
      }
  }

  getServerDataLeftAcc($event, section: any, index: number){
    if(!this.blockLeftAcc){
      this.blockRightAcc = false;
      this.firstResultDisplayAcc=this.firstResultDisplayAcc-5;
      this.countError = this.firstResultDisplayAcc+4;
      this.dataSourceErrors = new MatTableDataSource<any>(this.dataAppError.slice(this.firstResultDisplayAcc -1, this.countError));
      if( this.firstResultDisplayAcc<=1){
        this.blockLeftAcc = true;
      }
    }
  }

  getServerDataRightAcc($event, section: any, index: number){
    if(!this.blockRightAcc){
      this.flag = true;
      this.blockLeftAcc = false;
      this.firstResultDisplayAcc = this.countError + 1
      if(this.firstResultDisplayAcc + 4 <= this.dataAppError.length){
        this.countError = this.firstResultDisplayAcc + 4;
        this.blockRightAcc = false;
      }else{
        this.countError = this.dataAppError.length;
        this.blockRightAcc = true;
      }
        this.dataSourceErrors = new MatTableDataSource<any>(this.dataAppError.slice(this.firstResultDisplayAcc -1, this.countError));
    }
  }

  getServerDataLeftReg($event, section: any, index: number){
    if(!this.blockLeftReg){
      this.blockRightReg = false;
      this.firstResultDisplayReg=this.firstResultDisplayReg-5;
      this.countReturns = this.firstResultDisplayReg+4;
      this.dataSourceReturns = new MatTableDataSource<any>(this.dataAppReturns.slice(this.firstResultDisplayReg -1, this.countReturns));
      if( this.firstResultDisplayReg<=1){
        this.blockLeftReg = true;
      }
    }
  }

  getServerDataRightReg($event, section: any, index: number){
    if(!this.blockRightReg){
      this.flagReg = true;
      this.blockLeftReg = false;
      this.firstResultDisplayReg = this.countReturns + 1;
      if(this.firstResultDisplayReg + 4 <= this.dataAppReturns.length){
        this.countReturns = this.firstResultDisplayReg + 4;
        this.blockRightReg = false;
      }else{
        this.countReturns = this.dataAppReturns.length;
        this.blockRightReg = true;
      }
        this.dataSourceReturns = new MatTableDataSource<any>(this.dataAppReturns.slice(this.firstResultDisplayReg -1, this.countReturns));
    }
  }

ordinaSezioni(temp: FlowTable[]){
  for(let i = 0; i < temp.length-1; i++) {
    let minimo = i;
    for(let j = i+1; j < temp.length; j++) {
            if(temp[minimo].section>temp[j].section) {
                minimo = j;
            }
    }
    if(minimo!=i) { 
        let k = temp[minimo];
        temp[minimo]= temp[i];
        temp[i] = k;
    }
  }
}

section($event, section: any, index: number) {
  if(!this.filtered){
    this.countPratiche = undefined;
    this.filtered = true;
    this.filterFlow.firstResult = 0;
    this.filterFlow.maxResult = 10;
    this.firstResultDisplay = this.filterFlow.firstResult + 1;
    this.endPage = this.filterFlow.maxResult;
      this.activity.startingParams.extra = section;
      let colonne = Object.keys(section);
      if (!this.fkNameList || this.fkNameList.length === 0) {
        this.fkNameList = [];
        if (!this.fkNameList[index]) {
          this.fkNameList[index] = [];
        }
        let m = this.fmflow.flowTableList[index].flowTableFieldList.length;
        for (let n = 0; n < m; n++){
            for(let z = 0;z <this.fmflow.flowTableList.length; z++){
                if(this.fmflow.flowTableList[index].flowTableFieldList[n].pk){
                  const name = this.fmflow.flowTableList[index].flowTableFieldList[n].name;
                  if (!this.fkNameList[index].includes(name)) {
                    this.fkNameList[index].push(name);
                  }
                }
            }
          }
      }
      for(let i = 0; i < colonne.length; i++){
        for(let j = 0; j < this.fkNameList[index].length; j++){
          if(colonne[i] === this.fkNameList[index][j]){
            this.filterFlow.fkFields.push(this.fkNameList[index][j]);
            this.filterFlow.fkValues.push((section[this.fkNameList[index][j]]).toUpperCase());
            // this.filterFlow.param.push((section[this.fkNameList[index][j]]).toUpperCase());
            let filterFlowField: FilterFlowField = new FilterFlowField();
            filterFlowField.name = this.fkNameList[index][j];
            filterFlowField.section = String(index);
            filterFlowField.param = (section[this.fkNameList[index][j]]).toUpperCase();
            this.filterFlow.field.push(filterFlowField);
          }
        }
      }
      this.ricercaConf();
  }else{
    this.resetSearch();
  }
}

startSearch($event, i) {
  let allow: boolean = true;
  this.countPratiche = undefined;

  const normalize = (val: string) => val.toLowerCase().trim();

  // 🔹 Gestione CAMPI → VALORI (non Data)
  if (!this.hiddenDate) {
    const currentName = this.fieldApp ? normalize(this.fieldApp) : null;
    const currentValue =
      this.selectText && this.selectText.trim() !== ''
        ? this.selectText.trim()
        : null; // 🔸 Non aggiunge se valore vuoto

    if (!currentName || !currentValue) {
      return; // nessun campo o valore valido
    }

    const existingIndex = this.filterFlow.field.findIndex(
      f => normalize(f.name) === currentName
    );

    const newField: FilterFlowField = {
      name: currentName,
      section: i,
      param: currentValue
    };

    if (existingIndex >= 0) {
      this.filterFlow.field[existingIndex] = newField;
    } else {
      this.filterFlow.field.push(newField);
    }

    // 🔹 Rimuove duplicati residui
    this.filterFlow.field = this.filterFlow.field.filter(
      (f, idx, arr) => idx === arr.findIndex(o => normalize(o.name) === normalize(f.name))
    );
  }

  // 🔹 Gestione CAMPI → VALORI di tipo Data
  else {
    const currentName = this.fieldApp ? normalize(this.fieldApp) : null;
    if (!currentName) return;

    // Se entrambe le date sono vuote, ignora
    if (!this.dateInTemp && !this.dateOutTemp) return;

    // Se la data In > data Out, blocca
    if (this.dateInTemp && this.dateOutTemp && this.dateInTemp > this.dateOutTemp) {
      allow = false;
    }

    if (!allow) {
      this.activityManager.engApplication.notifyMessage(
        'La data di inizio periodo deve essere minore o uguale alla data di fine periodo'
      );
      return;
    }

    const existingIndex = this.filterFlow.fieldData.findIndex(
      f => normalize(f.name) === currentName
    );

    const newFieldData: FilterFlowFieldData = {
      name: currentName,
      section: i,
      dateIn: this.dateInTemp ? this.dateInTemp : undefined,
      dateOut: this.dateOutTemp ? this.dateOutTemp : undefined,
      position: this.dateInTemp && this.dateOutTemp ? 2
        : this.dateInTemp ? 0
        : this.dateOutTemp ? 1
        : 3 // posizione 3 = NULL (ma qui non verrà mai perché sopra filtriamo)
    };

    if (existingIndex >= 0) {
      this.filterFlow.fieldData[existingIndex] = newFieldData;
    } else {
      this.filterFlow.fieldData.push(newFieldData);
    }

    // 🔹 Rimuove duplicati residui
    this.filterFlow.fieldData = this.filterFlow.fieldData.filter(
      (f, idx, arr) => idx === arr.findIndex(o => normalize(o.name) === normalize(f.name))
    );
  }

  // 🔹 Aggiorna filtri indipendenti (Codice Azienda, Presidio, Tipologia Importazione)
  this.filterFlow.scartiRegione = this.scartiRegione;

  this.filterError.codiceAzienda =
    this.codiceAzienda && this.codiceAzienda.trim() !== ''
      ? this.codiceAzienda.trim()
      : null;
  this.filterFlow.codiceAzienda = this.filterError.codiceAzienda;

  this.filterError.codicePresidio =
    this.codicePresidio && this.codicePresidio.trim() !== ''
      ? this.codicePresidio.trim()
      : null;
  this.filterFlow.codicePresidio = this.filterError.codicePresidio;

  this.filterError.tipoImportazione =
    this.tipoImportazione && this.tipoImportazione.trim() !== ''
      ? this.tipoImportazione.trim()
      : null;
  this.filterFlow.tipoImportazione = this.filterError.tipoImportazione;

  // 🔹 Avvia ricerca se tutto valido
  if (allow) {
    this.filterFlow.firstResult = 0;
    this.filterFlow.maxResult = 10;
    this.firstResultDisplay = this.filterFlow.firstResult + 1;
    this.endPage = this.filterFlow.maxResult;
    this.ricercaConf();
  }
}

/**
 * 🔹 Selezione da combo Codice Azienda
 * - crea chip nel filtro
 * - resetta combo
 * - rimuove eventuali filtri "codicepresidio"
 * - ricarica lista presidi coerente
 */
onCodiceAziendaChange(event: any): void {
  const value = event.value.trim();

  if (value && value !== '') {
    this.applyIndependentFilter('codiceazienda', value);
  }
  this.fmflow.codiceazienda = value;

  // 🔹 Reset combo Codice Azienda
  this.codiceAzienda = '';
  event.source.writeValue('');
  this.aziendaControl.setValue('');

  // 🔹 Rimuove chip "codicepresidio" se presente
  const normalize = (v: string) => v.toLowerCase().trim();
  this.filterFlow.field = this.filterFlow.field.filter(f => normalize(f.name) !== 'codicepresidio');

  // 🔹 Reset valori e combo Codice Presidio
  this.codicePresidio = '';
  this.presidioControl.setValue('');
  this.filterFlow.codicePresidio = null;
  this.filterError.codicePresidio = null;

  // 🔹 Ricarica lista presidi per l'azienda selezionata
  this.presidiOptions = [];
  this.loadCodiciPresidio();

}

/**
 * 🔹 Selezione da combo Codice Presidio
 * - crea chip nel filtro
 * - resetta combo
 */
onCodicePresidioChange(event: any): void {
  const value = event.value;
  if (value && value.trim() !== '') {
    this.applyIndependentFilter('codicepresidio', value.trim());
  }

  this.codicePresidio = '';
  event.source.writeValue('');
  this.presidioControl.setValue('');
}

/**
 * 🔹 Selezione da combo Tipologia Importazione
 * - crea chip nel filtro
 * - resetta combo
 */
onTipologiaImportChange(event: any): void {
  const value = event.value;
  if (value && value.trim() !== '') {
    this.applyIndependentFilter('import_type', value.trim());
  }

  this.tipoImportazione = '';
  event.source.writeValue('');
  this.tipologiaControl.setValue('');
}

applyIndependentFilter(
    name: 'codiceazienda' | 'codicepresidio' | 'import_type',
    value: string
  ) {
    if (!value || value.trim() === '') return;
    const normalize = (v: string) => v.toLowerCase().replace(/\s+/g, '');
    const nName = normalize(name);     // ← SEMPRE codiceazienda, codicepresidio, import_type
    const nVal = value.trim();

    // ✅ label solo per il chip (visualizzazione)
    let displayLabel = nName;
    if (nName === 'codiceazienda' && this.codAziendaLabel.toLowerCase() === 'soggetto erogatore') {
      displayLabel = 'soggettoerogatore';   // solo label, non backend
    }

    // ⬆️ CHIP → aggiungiamo `label` oltre a `name`
    const idx = this.filterFlow.field.findIndex(f => normalize(f.name) === nName);
    const newField = { section: '0', name: nName, label: displayLabel, param: nVal };

    if (idx >= 0) this.filterFlow.field[idx] = newField;
    else this.filterFlow.field.push(newField);

    // ⬆️ Valori effettivi per il backend (restano invariati)
    if (nName === 'codiceazienda') {
      this.filterFlow.codiceAzienda = nVal;
      this.codiceAzienda = '';
      this.aziendaControl.setValue('');
    }

    if (nName === 'codicepresidio') {
      this.filterFlow.codicePresidio = nVal;
      this.codicePresidio = '';
      this.presidioControl.setValue('');
    }

    if (nName === 'import_type') {
      this.filterFlow.tipoImportazione = nVal;
      this.tipoImportazione = '';
      this.tipologiaControl.setValue('');
    }

    this.filterFlow.firstResult = 0;
    this.filterFlow.maxResult = 10;
    this.firstResultDisplay = 1;
    this.endPage = 10;
    this.ricercaConf();
  }

 refreshCombo($event, index) {
   if($event.value.fieldType == "Date"){
     this.hiddenDate = true;
     this.hiddenValue = true;
   }else{
    this.hiddenDate = false;
    this.hiddenValue = false;
   }
  let fieldN = $event.value.name;
  this.fieldApp = fieldN;
}

remove(field: any, index : number): void {  
  this.countPratiche = undefined;
  // this.filterFlow.param.splice(index,1);
  this.filterFlow.field.splice(index,1);

  // reset dei campi principali se il chip rimosso li rappresenta
  if (field.name.toLowerCase() === 'codice azienda') this.codiceAzienda = '';
  if (field.name.toLowerCase() === 'codice presidio') this.codicePresidio = '';
  if (field.name.toLowerCase() === 'tipologia importazione') this.tipoImportazione = '';

  this.ricercaConf();
}

// removeDate(date: Date, index: number): void {
//   this.countPratiche = undefined;
//   this.filterFlow.fieldData.splice(index,1);
//   this.ricercaConf();
// }

removeDateIn(date: Date, index: number): void {
  this.countPratiche = undefined;
  // this.filterFlow.dateIn.splice(index,1);
  if(this.filterFlow.fieldData[index].position == 0){
    this.filterFlow.fieldData.splice(index,1);
  }else if (this.filterFlow.fieldData[index].position == 2){
    this.filterFlow.fieldData[index].position = 1;
    this.filterFlow.fieldData[index].dateIn = undefined;
  }else if (this.filterFlow.fieldData[index].position == 3){
    this.filterFlow.fieldData.splice(index,1);
  }
  this.ricercaConf();
}

removeDateOut(date: Date, index: number): void {
  this.countPratiche = undefined;
  // this.filterFlow.dateOut.splice(index,1);
  if(this.filterFlow.fieldData[index].position == 1){
    this.filterFlow.fieldData.splice(index,1);
  }else if (this.filterFlow.fieldData[index].position == 2){
    this.filterFlow.fieldData[index].position = 0;
    this.filterFlow.fieldData[index].dateOut = undefined;
  }
  this.ricercaConf();
}

changeDateIn($event,index) {
  if ($event && $event.isTrusted) { return }
  if(index != this.selectedSection) { return }
  let dateIn = $event;
  this.dateInTemp = dateIn;
}

changeDateOut($event,index) {
  if ($event && $event.isTrusted) { return }
  if(index != this.selectedSection) { return }
  let dateOut = $event;
  this.dateOutTemp = dateOut
}

validaRecord(){

  if(this.showLoadingIndicator) {
    this.activityManager.engApplication.notifyMessage('Validazione in corso...');
    return;
  }

  if(this.filterFlow.fkFields.length > 0 && this.filterFlow.fkValues.length > 0){
    this.showLoadingIndicator = true;
    let list: string[][] = [];
    this.filterValid.field = [];
    for(let i = 0; i < this.filterFlow.fkValues.length; i++){
      let field : FilterFlowField = new FilterFlowField();
      field.name = this.filterFlow.fkFields[i];
      field.section = '0';
      field.param = this.filterFlow.fkValues[i];
      // this.filterValid.param[i] = this.filterFlow.fkValues[i];
      this.filterValid.field[i] = field;

      list[i] = [];
      list[i][0] = this.filter[i];
      list[i][1] = this.filterValue[i];
    }
    this.filterValid.flowId = this.filterFlow.flow.id;
    this.filterValid.versionId = this.filterFlow.flow.version;
    this.filterValid.importId = this.filterFlow.importId;

    this.flowConfigurationService.validateRecord(this.filterValid)
    .then(result => {
        this.showLoadingIndicator = false;

        if(result.opTargetObject) result = result.opTargetObject;

        if (result.success) {
          this.activityManager.engApplication.notifyMessage('Validazione effettuata con successo');
          this.ricercaConf();
        } else {
            // this.activityManager.engApplication.notifyMessage(result.messages[0]);
        }
    })
    .catch(e => {
      this.showLoadingIndicator = false;
      this.activityManager.engApplication.notifyMessage('Errore in fase di validazione');
    }
    ); 
  }else{
    this.activityManager.engApplication.notifyMessage('Selezionare record da validare');
  }
  
}

resetSearch() {
  this.fieldApp = null;
  this.countPratiche = undefined;
  this.filtered = false;
  this.filterFlow.firstResult = 0;
  this.filterFlow.maxResult = 10;
  this.endPage = this.filterFlow.maxResult;
  this.firstResultDisplay = this.filterFlow.firstResult + 1;

  // 🔹 svuota strutture di filtro
  this.filterFlow.field = [];
  this.filterFlow.fieldData = [];
  this.filterFlow.fkFields = [];
  this.filterFlow.fkValues = [];

  // 🔹 rimuove eventuali chip indipendenti (azienda/presidio/import)
  this.filterFlow.field = this.filterFlow.field.filter(
    f =>
      !['codiceazienda', 'codicepresidio', 'import_type'].includes(
        f.name.toLowerCase()
      )
  );

  // 🔹 reset variabili locali e FormControl
  this.codiceAzienda = null;
  this.codicePresidio = null;
  this.tipoImportazione = null;

  this.aziendaControl.reset(null);
  this.presidioControl.reset(null);
  this.tipologiaControl.reset(null);

  // 🔹 reset filterError + filterFlow campi espliciti
  this.filterError.codiceAzienda = null;
  this.filterFlow.codiceAzienda = null;
  this.filterError.codicePresidio = null;
  this.filterFlow.codicePresidio = null;
  this.filterError.tipoImportazione = null;
  this.filterFlow.tipoImportazione = null;

  this.fmflow.codiceazienda = null;
  this.scartiRegione = false;
  this.filterFlow.scartiRegione = false;
  this.emptyTables = false;

  // 🔹 ricarica combo dal backend
  this.loadCodiciAzienda();
  this.loadCodiciPresidio();

  // 🔹 aggiorna tabella
  this.ricercaConf();
}

getErrors($event, section: any, index: number) {
  if(this.expandedElement){
    this.filterError.accordionPag = true;
    this.firstResultDisplayAcc = 1;
    if(this.sectionBA==undefined || section!=this.sectionBA){
      this.sectionBA=section;
      this.flag = false;
      this.filterError.firstResultAcc = 0;
      this.firstResultDisplayAcc = this.filterError.firstResultAcc + 1;
      this.blockLeftAcc = true;
      this.endPageAcc = 5;
      this.blockRightAcc = true;
    }else if(this.sectionBA!=undefined || section==this.sectionBA){
      if(this.filterError.firstResultAcc<=1){
        this.blockLeftAcc = true;
      }else{
        this.blockLeftAcc = false;
      }
        this.endPageAcc = 5;
        this.blockRightAcc = true;
    }

    this.filterError.view = true;
    this.filterError.flow = this.fmflow;
    this.filterError.index = index;
    this.filterError.pkList = [];
    if (!this.pkNameList || this.pkNameList.length === 0) {
        const fieldList = this.fmflow.flowTableList[index].flowTableFieldList || [];
        this.pkNameList[index] = [];
        const pkFields = fieldList
          .filter(f => f.pk)                               // prendo solo i campi PK
          .sort((a, b) => a.position - b.position);         // ordino per posizione crescente
        pkFields.forEach(f => this.pkNameList[index].push(f.name)); // aggiungo i nomi in ordine
    }
    for(let i = 0; i < this.pkNameList[index].length; i++){
      this.filterError.pkList.push(section[this.pkNameList[index][i]]);
    }
    this.flowConfigurationService.getErrors(this.filterError)
      .then(result => {
          if (result.success) {
            this.mapErrors = result.opTargetObject.objectList;
            this.lenghtError = this.mapErrors.length;
               if(this.lenghtError== 0){
                  this.showLoadingIndicator = false;
                  this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                  this.blockRightAcc = true;
                  this.firstResultDisplayAcc = 0;
                  this.countError = 0;
                  this.displayedColumnsErrors = this.generaColonneErrors();
                  this.dataSourceErrors = null;
                }else{
                  this.displayedColumnsErrors = this.generaColonneErrors();
                  this.dataSourceErrors = new MatTableDataSource<any>(this.generateDatasourceErrors());
                }
          } else {
              this.activityManager.engApplication.notifyMessage('Errore in fase di ricezione degli errori');
          }
      })
      .catch(e => {
        this.activityManager.engApplication.notifyMessage('Errore in fase di ricezione degli errori');
      }
    );
  }
}

generaColonneErrors(): string[] {
  let colonne: string[] = []
  colonne.push("ERRORE", "DESCRIZIONE","CAMPO ERRATO", "VALORE ERRATO","DATA DI VALIDAZIONE","GRAVITA");
  return (colonne);
}

generateDatasourceErrors():Array<any>{
  let data = new Array();
  let columnValue = null;
  for(let z = 0; z < this.mapErrors.length; z++){
    data[z] = {};
    for(let i = 0; i < this.mapErrors[z].length; i++){
      columnValue = this.mapErrors[z][i];
      if(this.isDate(columnValue)){
        columnValue = this.dateConvert(columnValue);
      }
        let columnName = this.displayedColumnsErrors[i];
        data[z][columnName] = columnValue;
    }
  }
  this.blockLeftAcc = true;
  this.firstResultDisplayAcc = 1;
  let lenght = this.mapErrors.length;
  if(lenght <= 5){
  this.countError = lenght;
  this.blockRightAcc = true;
  }else{
    this.countError = 5;
    this.blockRightAcc = false;
    this.dataAppError = new Array();
    this.dataAppError = data;
    data = data.slice(0,5);
  }
  return data;
}

contaPratiche(lenght?: any, lastPage?:any){
this.filterFlow.count = true;
this.showLoadingIndicator = true;
  this.flowConfigurationService.countTables(this.filterFlow)
  .then(result => {
      if (result.success) {
        this.showLoadingIndicator = false;
        let mapCount = result.opTargetObject[0];
        let count = Object.keys(mapCount);
        this.countPratiche = +count[0];
        if(lenght!=undefined){
          this.filterFlow.count = false;
          this.showLoadingIndicator = true;
          this.flowConfigurationService.searchFlowView(this.filterFlow).then(result => {
            if (result.success) {
              this.showLoadingIndicator = false;
              this.fkNameList.length = 0;
              this.pkNameList.length = 0;
               this.map = result.opTargetObject[0];
               let m = this.fmflow.flowTableList[0].name;
               let lenght = this.map[m].length;
               if(lenght== 0){
                  this.showLoadingIndicator = false;
                  this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                  this.blockRight = true;
                  this.dataSource = [];
                 return;
               }else if(this.filterFlow.field.length>0 || this.filterFlow.fieldData.length>0){
                if(lenght==this.countPratiche || lenght<10){
                  this.blockRight = true;
                }
               }else if(lenght<10){
                  this.blockRight = true;
               }
               for(let i = 0; i < this.sezioni.length; i++){
                  this.generaColonne(i);
                  this.dataSource[i] = new MatTableDataSource<any>(this.generateDatasource(i));
                }
                this.selectText = undefined;
                this.selectedValue = undefined;
                this.dateInTemp = undefined;
                this.dateOutTemp = undefined;
            } else {
                this.showLoadingIndicator = false;
                this.activityManager.engApplication.notifyMessage('Errore in fase di caricamento delle colonne');
            }
          }).catch(() => {
          this.showLoadingIndicator = false;
          this.activityManager.engApplication.notifyMessage('Errore inaspettato');
        });


          // if(this.endPage==this.countPratiche){
          //   this.blockRight = true;
          // }
        }
        if(lastPage){
            let mod = this.countPratiche % 10;
            if(mod != 0){
              this.filterFlow.firstResult = this.countPratiche - mod;
            }else{
              this.filterFlow.firstResult = this.countPratiche - this.filterFlow.maxResult;
            }
            this.endPage = this.countPratiche;
            this.firstResultDisplay = this.filterFlow.firstResult + 1;
            this.filterFlow.count = false;
            this.ricercaConf();
        }
      } else {
          this.activityManager.engApplication.notifyMessage('Errore nel conteggio delle pratiche');
      }
      this.filterFlow.count = false;
  })
  .catch(e => {
    this.activityManager.engApplication.notifyMessage('Errore nel conteggio delle pratiche');
    this.filterFlow.count = false;
  }
);
}

    exportFileXLSX(filterFlow: FilterFlow) {
        this.download_ = true;
      this.header.label = "Download XLS in corso...";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);
      this.filterFlow.flow.flowTableList.forEach(fieldList => fieldList.flowTableFieldList.sort((a,b) => a. position - b.position));
      if (! this.colonneAggiunte) {
        for(let i=0; i<this.filterFlow.flow.flowTableList.length;i++){
          let c = this.filterFlow.flow.flowTableList[i].flowTableFieldList.length-1;
          let sys: FlowTableField = new FlowTableField();
          if (i==0){
            sys.name = "DATE_PROCESSING";
            sys.fieldType = "Date";
            sys.descriptionsm = "Data Ricezione";
            sys.position=c+1;
            this.filterFlow.flow.flowTableList[i].flowTableFieldList.push(sys);
            sys = new FlowTableField();
            sys.name = "STATUS_GROUP";
            sys.fieldType = "String";
            sys.descriptionsm = "Stato Validazione Pratica";
            sys.position=c+2;
            this.filterFlow.flow.flowTableList[i].flowTableFieldList.push(sys);
            sys = new FlowTableField();
            sys.name = "STATE_RECEVIED_APP";
            sys.fieldType = "String";
            sys.descriptionsm = "Stato Invio Da Verticale";
            sys.position=c+3;
            this.filterFlow.flow.flowTableList[i].flowTableFieldList.push(sys);
            sys = new FlowTableField();
            sys.name = "STATE_SEND_REGION";
            sys.descriptionsm = "Stato Invio A Regione";
            sys.fieldType = "String";
            sys.position=c+4;
            this.filterFlow.flow.flowTableList[i].flowTableFieldList.push(sys);
            sys = new FlowTableField();
            sys.name = "STATUS_REGION";
            sys.descriptionsm = "Stato Validazione Pratica Regionale";
            sys.fieldType = "String";
            sys.position=c+5;
            this.filterFlow.flow.flowTableList[i].flowTableFieldList.push(sys);
          }
          sys = new FlowTableField();
          sys.name = "STATUS";
          sys.descriptionsm = "Stato Validazione Record";
          sys.fieldType = "String";
          if (i==0){
            sys.position=c+6;
          } else {
            sys.position=c+2;
          }
          this.filterFlow.flow.flowTableList[i].flowTableFieldList.push(sys);
          sys = new FlowTableField();
          sys.name = "IMPORT_TYPE";
          sys.descriptionsm = "Tipo Importazione";
          sys.fieldType = "String";
          if (i==0){
            sys.position=c+7;
          } else {
            sys.position=c+2;
          }
          this.filterFlow.flow.flowTableList[i].flowTableFieldList.push(sys);
        }
        this.colonneAggiunte=true;
      }
      
      this.flowConfigurationService.downloadFlowViewXlsx(filterFlow).then(result => {
          if (result.size > 0) {
            this.header.visible = false;
            this.header.label = "";
            this.activityManager.getCurrentPage().setPageMainObject(this.header);
            var file = new Blob([result], {type: 'application/zip'});
            var fileURL = URL.createObjectURL(file);
            var anchor = document.createElement("a");
            anchor.download = "Pratiche flusso " + filterFlow.flow.name;
            anchor.href = fileURL;
            anchor.click();
              this.download_ = false;
              // window.open(fileURL);
          } else {
            this.activityManager.engApplication.notifyMessage('Nessun File trovato');
            this.header.visible = false;
            this.header.label = "";
            this.activityManager.getCurrentPage().setPageMainObject(this.header);
              this.download_ = false;
          }
    });


    }

    getReturns($event, section: any, index: number) {
    if(this.expandedElementReg){
      this.filterError.accordionReg = true;
      this.firstResultDisplayReg = 1;
      if(this.sectionBAreg==undefined || section!=this.sectionBAreg){
        this.sectionBAreg=section;
        this.flagReg = false;
        this.filterError.firstResultReg = 0;
        this.firstResultDisplayReg = this.filterError.firstResultReg + 1;
        this.blockLeftReg = true;
        this.endPageReg = 5;
        this.blockRightReg = true;
      }else if(this.sectionBAreg!=undefined || section==this.sectionBAreg){
        if(this.filterError.firstResultReg<=1){
          this.blockLeftReg = true;
        }else{
          this.blockLeftReg = false;
        }
          this.endPageReg = 5;
          this.blockRightReg = true;
      }

      this.filterError.flow = this.fmflow;
      this.filterError.index = index;
      this.filterError.pkList = [];
      this.filterError.pkNameList = [];
      /*
      for(let i = 0; i < this.pkNameList[index].length; i++){
        this.filterError.pkList.push(section[this.pkNameList[index][i]]);
        this.filterError.pkNameList.push(this.pkNameList[index][i]);
      }
      */
     this.retrieveConfig(section);
      /*let extractionId = null;
      if(this.filterFlow) {
        extractionId = this.filterFlow.importId;
      }
      this.flowConfigurationService.getReturns(this.filterError,extractionId)
      .then(result => {
          if (result.success) {
            this.mapReturns = result.opTargetObject;
            this.lenghtReturns = this.mapReturns["values"].length;
               if(this.lenghtReturns== 0){
                  this.showLoadingIndicator = false;
                  this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                  this.blockRightReg = true;
                  this.firstResultDisplayReg = 0;
                  this.countReturns = 0;
                  this.displayedColumnsReturns = this.generaColonneReturns();
                }else{
                  this.displayedColumnsReturns = this.generaColonneReturns();
                  this.dataSourceReturns = new MatTableDataSource<any>(this.generateDatasourceReturns());
                }
          } else {
            this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
          }
      })
      .catch(e => {
        this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
      }
    );*/
    }
  }

  retrieveConfig(section: any){
   this.showLoadingIndicator = true;
    this.flowConfigurationService.searchTabgenFields(this.fmflow.name + "_SCARTI_REGIONE").then(response => {
        if (response.success) {
            if (response.opTargetObject.error) {
            } else {
                for(let i=0; i<response.opTargetObject.items.length; i++){
                    if(response.opTargetObject.items[i].description == "CAMPO_CHIAVE"){
                        var campoChiave = response.opTargetObject.items[i].tabgenValueColumn;
                    }
                    if(response.opTargetObject.items[i].description == "NOME_CAMPO"){
                      var nomecampo = response.opTargetObject.items[i].tabgenValueColumn;
                  }
                }
                let filterGlob: SearchFilters = new SearchFilters();
                filterGlob.tabgenId = this.fmflow.name + "_SCARTI_REGIONE";
                this.flowConfigurationService.tabgenValueListSearchDataProvider(filterGlob).then(response => {
                    if (response.success) {
                        if (response.opTargetObject.error) {
                        } else {
                            for(let i=0; i<response.opTargetObject.items.length; i++){
                                if(response.opTargetObject.items[i][campoChiave.toLowerCase()] == "1"){
                                    let nomeCampo = response.opTargetObject.items[i][nomecampo.toLowerCase()];
                                    this.campiConfig.push(nomeCampo.toLowerCase());
                                }
                            }
                            for(let j=0; j<this.campiConfig.length; j++){
                                this.filterError.pkNameList.push(this.campiConfig[j]);
                                this.filterError.pkList.push(section[this.campiConfig[j]]);
                                // this.valoriConfig.push(section[this.campiConfig[j]]);
                            }
                            let extractionId = null;
                            if(this.filterFlow) {
                              extractionId = this.filterFlow.importId;
                            }
                            this.flowConfigurationService.getReturns(this.filterError,extractionId)
                            .then(result => {
                                if (result.success) {
                                  this.mapReturns = result.opTargetObject;
                                  this.lenghtReturns = this.mapReturns["values"].length;
                                    if(this.lenghtReturns== 0){
                                        this.showLoadingIndicator = false;
                                        this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                                        this.blockRightReg = true;
                                        this.firstResultDisplayReg = 0;
                                        this.countReturns = 0;
                                        this.displayedColumnsReturns = this.generaColonneReturns();
                                      }else{
                                        this.displayedColumnsReturns = this.generaColonneReturns();
                                        this.dataSourceReturns = new MatTableDataSource<any>(this.generateDatasourceReturns());
                                      }
                                } else {
                                  this.showLoadingIndicator = false;
                                  this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                                }
                                this.showLoadingIndicator = false;
                            })
                            .catch(e => {
                              this.showLoadingIndicator = false;
                              this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                            }
                          );
                        }
                    }
                    this.showLoadingIndicator = false;
                }).catch(() => {
                    this.showLoadingIndicator = false;
                    let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
                    this.activityManager.engApplication.notifyMessage(errorMessage);
                });
            }
            this.showLoadingIndicator = false;
        } else {
            this.showLoadingIndicator = false;
            let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
            this.activityManager.engApplication.notifyMessage(errorMessage);
        }        
    }).catch(() => {
        this.showLoadingIndicator = false;
        let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
        this.activityManager.engApplication.notifyMessage(errorMessage);
    });
}

  generaColonneReturns(): string[] {
    let colonne: string[] = [];
    let lenght = this.mapReturns["columns"].length;
    for(let i=0; i< lenght; i++){
      colonne.push(this.mapReturns["columns"][i]);
    }
    return (colonne);
  }
  
  generateDatasourceReturns():Array<any>{
    let data = new Array();
    let columnValue = null;
    let lenght = this.mapReturns["values"].length;
    for(let z = 0; z < lenght; z++){
      data[z] = {};
      let lengthColumn = this.mapReturns["columns"].length;
      for(let i = 0; i < lengthColumn; i++){
        let columnName = this.displayedColumnsReturns[i];
        columnValue = this.mapReturns["values"][z][columnName];
        data[z][columnName] = columnValue;
      }
    }
    this.blockLeftReg = true;
    this.firstResultDisplayReg = 1;
    if(lenght <= 5){
      this.countReturns = lenght;
      this.blockRightReg = true;
    }else{
      this.countReturns = 5;
      this.blockRightReg = false;
      this.dataAppReturns = new Array();
      this.dataAppReturns = data;
      data = data.slice(0,5);
  }
    return data;
  }

  searchFromPatient(element){
    let colonne = Object.keys(element);
    this.filtered = true;
    for(let i=0; i<colonne.length; i++){
      let field = colonne[i].replace(/\s/g, "");
      this.filterFlow.fkFields.push(field);
      this.filterFlow.fkValues.push((element[colonne[i]]).toUpperCase());
      // this.filterFlow.param.push((element[colonne[i]]).toUpperCase());
      let filterFlowField: FilterFlowField = new FilterFlowField();
      filterFlowField.name = field;
      filterFlowField.section = "0";
      filterFlowField.param = (element[colonne[i]]).toUpperCase();
      this.filterFlow.field.push(filterFlowField);
    }
    this.ricercaConf();

  }

  isEditModeEdit(){
    let starterParams: any = this.activity.startingParams;
    if(starterParams.extra && Object.keys(starterParams.extra).length > 0){
      return false;
    }
  }

  sortData(event,index){
    this.filterFlow.sortField = event.active;
    this.filterFlow.sortDir = event.direction;
    this.filterFlow.sortSez = index;
    this.ricercaConf();
  }

  goToLastPage(){
    if(this.countPratiche==undefined){
      this.showLoadingIndicator = true;
      let lenght = undefined;
      let lastPage = true;
      this.contaPratiche(lenght,lastPage);
    }else{
      let mod = this.countPratiche % 10;
      if(mod != 0){
        this.filterFlow.firstResult = this.countPratiche - mod;
      }else{
        this.filterFlow.firstResult = this.countPratiche - this.filterFlow.maxResult;
      }
      this.endPage = this.countPratiche;
      this.firstResultDisplay = this.filterFlow.firstResult + 1;
      this.ricercaConf();
    }
  }

  goToFirstPage(){
    if(!this.blockLeft){
      this.showLoadingIndicator = true;
      this.filterFlow.firstResult = 0;
      this.filterFlow.maxResult = 10;
      if(this.totalItems<=this.filterFlow.maxResult){
        this.endPage = this.totalItems;
      }else{
        this.endPage = this.filterFlow.maxResult
      }
      this.firstResultDisplay = this.filterFlow.firstResult + 1;
      this.ricercaConf();
    }
  }

}
