    countError: number;
    countReturns: number;
    count: number[] = [];
    dataApp: any[][] = [];
    dataAppError: any[] = [];
    dataAppReturns: any[] = [];
    firstResultSez: number[] = [];
    blockRightSez: boolean[] = [];
    blockLeftSez: boolean[] = [];
    fieldSys: FlowTableField[] = [];
    filtered: boolean = false;
    iToolbar: number = 0;
