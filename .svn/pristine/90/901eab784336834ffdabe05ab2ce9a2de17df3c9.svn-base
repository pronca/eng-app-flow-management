    aziendeOptions: string[] = [];
    presidiOptions: string[] = [];

    filteredAziende: Observable<string[]>;
    filteredPresidi: Observable<string[]>;

    tipologiaControl = new FormControl();
    tipologiaOptions: string[] = [
      'FROM_REST_SERVICE',
      'FROM_TABLE',
      'FROM_FILE_UPLOAD',
      'FROM_EXPORTING_JOB'
    ];
    filteredTipologie: Observable<string[]>;
