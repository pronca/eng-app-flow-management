@import 'theme-settings.scss';



:host {
    display: flex;
}

.badge {
    
    @include mat-elevation(5);
    flex: 1;
    margin: 10px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background-color: white;
    flex-direction: column;
    
    .bend{
        width: 100%;
        height: 5px;
        background-color: $primary-color;
    }

    .header:hover{
        cursor: pointer;
    }

   
    .header {
        // background-color: $primary-color;
        // color: $primary-color-contrast;
       
        padding: 10px;
        color: #004545;
        background-color: #F0F0F0;
        font-size: medium;
        //color: $primary-color;
        font-weight: bold;
        cursor: pointer;
        
            
        ::ng-deep .item-info .label {
            display: inline-block;
        }
    }

    .content {
        display: flex;
        cursor: pointer;
        /* 
        removed for IE compatibility (in ie this makes badges content collapse)
        flex: 1;
        */
        padding-right: 10px;
        padding-left: 10px;

        //.left-col {
        //}

        .body {
            margin-top:5px;
            padding-left: 10px;
            font-size: small;
            flex: 1;
            
        }
        
    }
    .footer {
        border-top: 1px solid #007575;
        display: flex;
        font-size: 12px;
        justify-content: flex-start;
        align-items: flex-end;
        margin: 0px;
        flex: 2;
      }
}


.mat-button{
    box-sizing: border-box;
    position: relative;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    cursor: pointer;
    outline: 0;
    border: none;
    -webkit-tap-highlight-color: transparent;
    display: inline-block;
    white-space: nowrap;
    text-decoration: none;
    vertical-align: baseline;
    text-align: center;
    margin: 0;
    margin-left: -15px;
    min-width: 0;
    line-height: 0;
    padding: 0 16px;
    border-radius: 4px;
    overflow: visible;
}


.box-image { 
    width: 50px;
    height: 50px;
    background-size: 100%;

}

.disable {
    color: #c4c4c4;
    cursor: default;
}

.rotate {
    transform: rotate(270deg)
}

.state {
    overflow: scroll;
}

.action {
    float: right!important;
    padding: 3px;
    margin-left: auto;
    cursor: pointer;
}

.margin {
    padding: 0px 6px 0px 5px;
}

.material-icons--animating {
    cursor: pointer;
  }

  
