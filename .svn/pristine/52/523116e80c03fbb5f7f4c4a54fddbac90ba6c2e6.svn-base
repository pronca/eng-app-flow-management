 //Dragover listener
 @HostListener('dragover', ['$event']) onDragOver(evt) {
  evt.preventDefault();
  evt.stopPropagation();
  // this.background = '#9ecbec';
  this.opacity = '0.8'
}

//Dragleave listener
@HostListener('dragleave', ['$event'])
public onDragLeave(evt) {
  evt.preventDefault();
  evt.stopPropagation();
  //this.background = '#f5fcff'
  this.opacity = '1'
}

//Drop listener
@HostListener('drop', ['$event'])
public ondrop(evt) {
  evt.preventDefault();
  evt.stopPropagation();
  //this.background = '#f5fcff'
  this.opacity = '1'
  let files = evt.dataTransfer.files;
  if (files.length > 0) {
      this.onFileDropped.emit(files)
  }
}

allowDrop(ev) {
  ev.preventDefault();
}

uploadReturns(el, year: any) {
  let inputFile = el.files[0];
  el.value = '';
  this.readFile(inputFile).then((file) => {

      this.file = [file];
      this.files = [file.name];

      let successMessage: string = this.activityManager.engApplication.i18nInstant('!i18n# File caricato');
      this.activityManager.engApplication.notifyMessage(successMessage);

      // let el: HTMLElement = document.getElementById('uploadReturnsInput');
      // el.nodeValue = undefined;

      this.saveFile(file, year);
  });
}

readFile(inputFile: any): Promise<{
  name: string;
  size: number;
  type: string;
  content: any
}> {
  let deferred = Promises.defer<any>()
  var reader = new FileReader();
  reader.onload = (onLoadEvent) => {
      var arrayBuffer = onLoadEvent.target['result'];
      console.log("on Load ", onLoadEvent);
      deferred.resolve({
          name: inputFile.name,
          size: inputFile.size,
          type: inputFile.type,
          content: arrayBuffer
      });
  };
  reader.onprogress = (progressEvent) => {
      console.log("onprogress ", progressEvent)
  };
  reader.readAsArrayBuffer(inputFile);
  return deferred.promise;
}

saveFile(file: any, year: any){
  this.header.visible = true;
  this.header.label = "Upload file in corso..";
  this.activityManager.getCurrentPage().setPageMainObject(this.header);

  this.flowConfigurationService.saveReturnsFilesTot(file,this.fmflow.id,this.version, year.toString()).then(response => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);

      let result: any = response.opTargetObject;
      if (result.success) {
          let successMessage: string = this.activityManager.engApplication.i18nInstant('!i18n# Upload avvenuto con successo');
          this.activityManager.engApplication.notifyMessage(successMessage);
      } else {
          this.choices = [];
          this.choices.push(this.choice);
          this.activity.getUserConfirmService().askChooseOneMessage(this.choices, 'Attenzione', result.message)
              .then(function () {
                      return;
                  }
              );
      }
  }).catch((e) => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);

      let errorMessage: string = this.activityManager.engApplication.i18nInstant('!i18n# Errore Inaspettato');
      this.activityManager.engApplication.notifyMessage(errorMessage);
  });
  // return Promise.resolve();
  }

  getCanViewMonthOrDateFromToFilters(flowName: string) {

    let filter: SearchFilters = new SearchFilters();
    let flowEnabledList: string = "";
    filter.tabgenId = "DASHBOARD_EXTRA_CONFIG";
    return this.flowConfigurationService.tabgenValueListSearchDataProvider(filter).then(response => {
      if (response.success) {
        if (response.opTargetObject.error) {
          this.canViewMonthFromToFilters = false;
          this.canViewDateFromToFilters = false;
        } else {
          //gestione per range di mesi
          for(let i=0; i<response.opTargetObject.items.length; i++) {
            if(response.opTargetObject.items[i]["field1"] === "monthFromToFilterEnableForBadge") {
              flowEnabledList = response.opTargetObject.items[i]["field3"];
            }
          }
          if (flowEnabledList !== null && flowEnabledList !== "") {
            var isPresentMonth = false;
            var flowList = flowEnabledList.split(',');
            for(let i=0; i<flowList.length; i++) {
              if(!isPresentMonth && flowList[i].toLowerCase() === flowName.toLowerCase()) {
                isPresentMonth = true;
              }
            }
            this.canViewMonthFromToFilters = isPresentMonth;
          }
          //gestione per range di date
          for(let i=0; i<response.opTargetObject.items.length; i++) {
            if(response.opTargetObject.items[i]["field1"] === "dateBetweenToFilterEnableForBadge") {
              flowEnabledList = response.opTargetObject.items[i]["field3"];
            }
          }
          if (flowEnabledList !== null && flowEnabledList !== "") {
            var isPresentDate = false;
            var flowList = flowEnabledList.split(',');
            for(let i=0; i<flowList.length; i++) {
              if(!isPresentDate && flowList[i].toLowerCase() === flowName.toLowerCase()) {
                isPresentDate = true;
                //se 1 flusso è parametrizzato per entrambi le configurazioni prevale quella per range di data
                this.canViewMonthFromToFilters = false;
              }
            }
            this.canViewDateFromToFilters = isPresentDate;
          }
        }
      } 
    }).catch(() => {
      let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
      this.activityManager.engApplication.notifyMessage(errorMessage);
      this.canViewMonthFromToFilters = false;
      this.canViewDateFromToFilters = false;
    });
    
  }

  getExtraFilterValues(flowName: string) {
    let filter: SearchFilters = new SearchFilters();
    let comboBoxTable: string = "";
    filter.tabgenId = "DASHBOARD_EXTRA";
    return this.flowConfigurationService.tabgenValueListSearchDataProvider(filter).then(response => {
      if (response.success) {
        if (response.opTargetObject.error) {
        } else {
          for(let i=0; i<response.opTargetObject.items.length; i++) {
            if(response.opTargetObject.items[i]["field1"].toLowerCase() === flowName.toLowerCase()) {
              let filter = new ExtraFilter();
              filter.campo = response.opTargetObject.items[i]["field2"];
              filter.label = "!i18n#" + response.opTargetObject.items[i]["field4"];
              filter.selected = "";
              this.extraFilter.push(filter);
              comboBoxTable = response.opTargetObject.items[i]["field3"];
              this.buildValueSet(filter.campo, comboBoxTable).then(response => {
                
              });
            }
          }
          
        }
      } 
    }).catch(e => {
      console.error(e);
      let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
      this.activityManager.engApplication.notifyMessage(errorMessage);
    });
  }

  buildValueSet(campo:string, comboBoxTable: string): Promise<any> {
    if (comboBoxTable !== null) {
      let filter: SearchFilters = new SearchFilters();
      let valuesList: ExtraFilterValueSet[] = [];
      filter.tabgenId = comboBoxTable.toUpperCase();
      return this.flowConfigurationService.tabgenValueListSearchDataProvider(filter).then(response => {
        if (response.success) {
          if (response.opTargetObject.error) {
          } else {
            for(let i=0; i<response.opTargetObject.items.length; i++) {
              let value = new ExtraFilterValueSet();
              value.code = response.opTargetObject.items[i]["field1"];
              value.display = "!i18n#" + response.opTargetObject.items[i]["field2"];
              valuesList.push(value);
            }
            this.valueSetsService.registerLocalValueSet(campo.toLowerCase() + "-filter-value-set", valuesList);
          }
        } 
      }).catch(() => {
        let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
        this.activityManager.engApplication.notifyMessage(errorMessage);
      });
    }
    return Promise.resolve(null as any).then();
  }

  serachDashDateFrom(date: Date) {
    if (!date) return;

    // normalizzo a inizio giornata
    this.valueFilterDateFrom = new Date(date.getFullYear(), date.getMonth(), date.getDate(), 0, 0, 0, 0);

    // se FROM > TO, riallineo TO alla stessa data (fine giornata)
    if (this.valueFilterDateTo && this.valueFilterDateFrom > this.valueFilterDateTo) {
      this.valueFilterDateTo = new Date(date.getFullYear(), date.getMonth(), date.getDate(), 23, 59, 59, 999);
    }
  }

  serachDashDateTo(date: Date) {
    if (!date) return;

    // normalizzo a fine giornata
    this.valueFilterDateTo = new Date(date.getFullYear(), date.getMonth(), date.getDate(), 23, 59, 59, 999);

    // se TO < FROM, riallineo FROM alla stessa data (inizio giornata)
    if (this.valueFilterDateFrom && this.valueFilterDateTo < this.valueFilterDateFrom) {
      this.valueFilterDateFrom = new Date(date.getFullYear(), date.getMonth(), date.getDate(), 0, 0, 0, 0);
    }
  }

}
