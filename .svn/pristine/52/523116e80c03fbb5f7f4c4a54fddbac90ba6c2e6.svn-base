      this.valueFilterMonthTo = starterParams.extra[2];
    }

    this.fmflow = starterParams.editItem;
    ;

    this.version = starterParams.editItem.version;
    Promise.all([this.getExtraFilterValues(this.fmflow.name),
    this.getCanViewMonthOrDateFromToFilters(this.fmflow.name)]).then(([list, data]) => {
      this.getRegionBadge();
    });
    /* ----------==========     Daily Sales Chart initialization For Documentation    ==========---------- */


    this.valueSetsService.registerLocalValueSet("month-value-set", [
      {
