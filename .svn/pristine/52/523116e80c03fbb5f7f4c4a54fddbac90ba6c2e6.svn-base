  serachDashFilter($event, filter: ExtraFilter) {
    if (this.extraFilter !== null) {
      let select = this.extraFilter.filter(f => f.campo === filter.campo)[0];
      if (select !== null) {
        let index = this.extraFilter.indexOf(select);
        select.selected = $event;
        this.extraFilter[index] = select;
      }
    }
  }

  serachDashMFrom($event) {

    this.valueFilterMonthFrom = $event;

  }


  serachDashMTo($event) {

    this.valueFilterMonthTo = $event;

  }

  serachDashYFromTo($event) {

    this.valueFilterYear = $event;

  }

  startSearch() {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.getRegionBadge();
  }

  
  serachDashY($event) {
    this.valueFilterYear = $event;
    var date = new Date();
    if (this.valueFilterYear != date.getFullYear() || this.valueFilterMonth != (date.getMonth() + 1)) {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = false;
      this.visibleOld = true;
    } else {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = true;
      this.visibleOld = false;
    }

    this.getAll();
  }

  serachDashM($event) {

    this.valueFilterMonth = $event;
    var date = new Date();
    if (this.valueFilterMonth != (date.getMonth() + 1) || this.valueFilterYear != date.getFullYear()) {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = false;
      this.visibleOld = true;
      this.getRegionBadge();

    } else {
      this.lineChartData = [];
      this.lineChartData3 = [];
      this.visible = true;
      this.visibleOld = false;
      this.getAll();

    }


  }


  downloadXLSXCheck(tipo: String, name: String){
    if(!this.download_){
      this.exportFileXLSX(tipo, name);
    }
    else{
      this.activityManager.engApplication.notifyMessage('Download File XLS in corso, attendere il completamento');
    }
  }



  exportFileXLSX(tipo: String, name: String) {
    this.download_ = true;
    this.header.visible = true;
    this.header.label = "Donwloading XLS";

    this.activityManager.getCurrentPage().setPageMainObject(this.header);

    this.flowConfigurationService.downloadFlowErrorXlsx(this.fmflow, this.valueFilterMonth, this.valueFilterYear, tipo, name, this.valueFilterMonthFrom, this.valueFilterMonthTo, this.canViewMonthFromToFilters, this.canViewDateFromToFilters, this.valueFilterDateFrom, this.valueFilterDateTo).then(result => {
      if (result.size > 0) {
        var file = new Blob([result], { type: 'application/zip' });
        var fileURL = URL.createObjectURL(file);
        var anchor = document.createElement("a");
        if (name=='PRATICHE_NOT_SEND_REG') {
          anchor.download = "Pratiche NON inviate in Regione flusso " + this.fmflow.name; 
        } else if (name=='PRATICHE_REG') {
          anchor.download = "Pratiche Inviate A Regione flusso " + this.fmflow.name; 
        } else if (name=='PRATICHE_RIC_REG') {
          anchor.download = "Pratiche Riconosciute Da Regione flusso_ " + this.fmflow.name; 
        } else if (name=='ERRORI') {
          anchor.download = "Errori pratiche flusso " + this.fmflow.name; 
        } else if (name=='ERRORI_REG') {
          anchor.download = "Errori regionali flusso " + this.fmflow.name; 
        } else if (name=='PRATICHE') {
          anchor.download = "Pratiche flusso " + this.fmflow.name; 
        } else if (name=='PRATICHE_ERRATE') {
          anchor.download = "Pratiche Errate flusso " + this.fmflow.name; 
        } else if (name=='PRATICHE_ERRATE_REG') {
          anchor.download = "Pratiche Errate Regionali flusso " + this.fmflow.name; 
        } else if (name=='PRATICHE_SEGNALAZIONI_REG') {
          anchor.download = "Pratiche Segnalazioni Regionali flusso " + this.fmflow.name; 
        } else {
          anchor.download = name+"_"+this.fmflow.name; 
        }
        
        anchor.href = fileURL;
        anchor.click();
        // window.open(fileURL);

        this.header.visible = false;
        this.header.label = "";
        this.activityManager.getCurrentPage().setPageMainObject(this.header);
        this.download_ = false;

      } else {
        this.activityManager.engApplication.notifyMessage('Nessun file presente');
        this.download_ = false;
      }
    });

  }

