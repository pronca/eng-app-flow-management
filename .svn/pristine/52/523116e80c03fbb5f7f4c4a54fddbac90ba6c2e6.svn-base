  initActivityActions() {
    super.initActivityActions();
    this.activity.removeActivityAction(EditActivityComponent.SAVE_ACTION);

    this.activity.addActivityAction({
      actionType: ActivityActionType.MAIN,
      name: EditActivityComponent.SAVE_ACTION,
      tooltip: "Annulla validazione e NON invia i risultati ai verticali",
      icon: "undo",
      fn: (activity, action) => {
          this.resetValidation();  
          return Promise.resolve(null);            
      }
    });

    this.activity.addActivityAction({
      actionType: ActivityActionType.MAIN,
      name: EditActivityComponent.SAVE_ACTION,
      tooltip: "Avvia Validazione trasversale",
      icon: "done_all",
      fn: (activity, action) => {
          this.crossValidation();  
          return Promise.resolve(null);            
      }
    });

    this.activity.addActivityAction({
      actionType: ActivityActionType.MAIN,
      name: EditActivityComponent.SAVE_ACTION,
      tooltip: "Valida / rivalida e invia i risulati ai verticali",
      icon: "spellcheck",
      fn: (activity, action) => {
          this.firstValidation();
      return Promise.resolve(null);                   
      }
    });

   // this.getRegionBadge();
  }

  firstValidation() {
    this.header.visible = true;
    this.header.label = "Validazione in corso";
    this.activityManager.getCurrentPage().setPageMainObject(this.header);

    let filterValid : FilterValid = new FilterValid();

    // filterValid.param = [this.valueFilterMonth.toString(),this.valueFilterYear.toString()];

    let month : FilterFlowField = new FilterFlowField();
    month.name = 'MONTH_RIF';
    month.section = '0';
    month.param = this.valueFilterMonth.toString();

    let year : FilterFlowField = new FilterFlowField();
    year.name = 'YEAR_RIF';
    year.section = '0';
    year.param = this.valueFilterYear.toString();

    filterValid.field = [month,year];
    filterValid.flowId = this.fmflow.id;

    this.flowConfigurationService.validateRecords(filterValid)
      .then(result => {
          let resultVal = result.opTargetObject;

          if (result.success) {
            let validationId = resultVal.result;

            this.sub = this.ping.subscribe((val) => {
              this.checkValidation(validationId);
            });            
          } else {
            this.activityManager.engApplication.notifyMessage('Errore in fase di gestione della richiesta di validazione');
          }
      })
      .catch(e => {
        this.header.visible = false;
        this.header.label = "";
        this.activityManager.getCurrentPage().setPageMainObject(this.header);

        this.activityManager.engApplication.notifyMessage('Errore in fase di validazione');
      }
    );
  }

  checkValidation(validationId) {
    this.flowConfigurationService.checkValidation(validationId).then(result => {
      let resultVal = result.opTargetObject;
      if(resultVal.result) {
        this.header.visible = false;
        this.header.label = "";
        this.activityManager.getCurrentPage().setPageMainObject(this.header);
        this.activityManager.engApplication.notifyMessage('Validazione terminata');
        this.sub.unsubscribe();
      }
    }).catch(e => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);
      this.sub.unsubscribe();
      this.activityManager.engApplication.notifyMessage('Errore in fase di validazione');
    });
  }

  crossValidation() {
    this.header.visible = true;
    this.header.label = "Validazione trasversale in corso";
    this.activityManager.getCurrentPage().setPageMainObject(this.header);

    let validationFilter = {
      flowId : this.fmflow.id,
      month : this.valueFilterMonth.toString(),
      year : this.valueFilterYear.toString()
    };

    this.flowConfigurationService.crossValidation(validationFilter)
    .then(result => {
      let resultVal = result.opTargetObject;

      if (result.success) {
        let validationId = resultVal.result;

        this.sub = this.ping.subscribe((val) => {
          this.checkSecondLevelValidation(validationId);
        });            
      } else {
          this.activityManager.engApplication.notifyMessage('Errore in fase di gestione della richiesta di validazione');
          this.header.visible = false;
          this.header.label = "";
          this.activityManager.getCurrentPage().setPageMainObject(this.header);
      }
    })
    .catch(e => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);
      this.sub.unsubscribe();
      this.activityManager.engApplication.notifyMessage('Errore in fase di gestione della richiesta di validazione');
    }
    );
  }

  checkSecondLevelValidation(validationId) {
    this.flowConfigurationService.checkSecondLevelJob(validationId).then(result => {
      let resultVal = result.opTargetObject;
      if(resultVal.result) {
        this.header.visible = false;
        this.header.label = "";
        this.activityManager.getCurrentPage().setPageMainObject(this.header);
        this.activityManager.engApplication.notifyMessage('Validazione trasversale terminata');
        this.sub.unsubscribe();
      }
    }).catch(e => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);
      this.sub.unsubscribe();
      this.activityManager.engApplication.notifyMessage('Errore in fase di validazione');
    });
  }

  resetValidation() {
    this.header.visible = true;
    this.header.label = "Annullamento validazione in corso";
    this.activityManager.getCurrentPage().setPageMainObject(this.header);

    let validationFilter = {
      flowId : this.fmflow.id,
      month : this.valueFilterMonth.toString(),
      year : this.valueFilterYear.toString()
    };

    this.flowConfigurationService.resetValidation(validationFilter)
    .then(result => {
      let resultVal = result.opTargetObject;

      if (result.success) {
        let validationId = resultVal.result;

        this.sub = this.ping.subscribe((val) => {
          this.checkResetValidation(validationId);
        });            
      } else {
          this.activityManager.engApplication.notifyMessage('Errore in fase di gestione della richiesta di annullamento validazione');
          this.header.visible = false;
          this.header.label = "";
          this.activityManager.getCurrentPage().setPageMainObject(this.header);
      }
    })
    .catch(e => {
      this.activityManager.engApplication.notifyMessage('Errore in fase di gestione della richiesta di annullamento');
    }
    );
  }

  checkResetValidation(validationId) {
    this.flowConfigurationService.checkResetJob(validationId).then(result => {
      let resultVal = result.opTargetObject;
      if(resultVal.result) {
        this.header.visible = false;
        this.header.label = "";
        this.activityManager.getCurrentPage().setPageMainObject(this.header);
        this.activityManager.engApplication.notifyMessage('Annullamento validazione terminato');
        this.sub.unsubscribe();
      }
    }).catch(e => {
      this.header.visible = false;
      this.header.label = "";
      this.activityManager.getCurrentPage().setPageMainObject(this.header);
      this.sub.unsubscribe();
      this.activityManager.engApplication.notifyMessage('Errore in fase di annullamento validazione');
    });
  }

  getAll() {
    this.lineChartLabels2 = [];
    this.visibleError = false;
    this.visibleScarto = false;
    this.visiblePratiche = false;

    this.getDynamicBadge();
    this.getDashboardForPratiche();
    this.getDashboardForErrors();
    
  }


