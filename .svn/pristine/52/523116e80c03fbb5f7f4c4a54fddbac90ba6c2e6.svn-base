  //valueFilterDateFrom = new Date(this.valueFilterYear, 0, 1, 0, 0, 0, 0); // 1 Gennaio anno in corso
  valueFilterDateFrom = new Date(today.getFullYear(), today.getMonth(), 1, 0, 0, 0, 0); // primo giorno del mese corrente
  valueFilterDateTo   = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 23, 59, 59, 999);
