.flowtype-label input {
  text-align: right !important;
}

#form2 {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-items: flex-start;
  padding: 20px;
  // to make space for floating buttons
  // margin-bottom: 50px;
}

#form2 > * {
  width: 100%;
  padding-bottom: 10px;
}

.dettaglio{
  margin-bottom: 15px !important;
}


.example-card {
  box-shadow: 2px 6px 9px 3px rgba(200,200,200,1);
-webkit-box-shadow: 2px 3px 9px 3px rgba(200,200,200,1);
-moz-box-shadow: 2px 3px 9px 3px rgba(200,200,200,1);
  padding: 10px;
  margin-left: 10px;
  margin-top: 10px;
  font-family: -apple-system,system-ui,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;
  font-size: 1rem;
  font-weight: 400;
  line-height: 1.5;
  color: #292b2c;
  border: 1px;
margin: 8px;
padding-bottom: 50px;
// background-color: #fafafa;
}

::ng-deep .mat-step-header .mat-step-icon-selected {
  background-color:  #FF5722; 
}

::ng-deep .mat-horizontal-content-container {
  background-color: #fafafa;
}

::ng-deep .mat-horizontal-stepper-header-container {
  background-color: #fafafa;
}

::ng-deep .mat-card-title{
  display: block;
  margin-bottom: 8px;
  padding: 10px;
  color: #004545;
  // background-color: #F0F0F0;
  font-size: 20px;
  font-weight: bold;
  cursor: pointer; 
}

.mat-expansion-panel{
  margin: 8px;

}

.mat-title{
  min-height: 0px !important;
  text-transform: uppercase;
  font-weight: bold;
  min-width: 90%;
  font-size: 16px;
  margin: 0px 3px 0px 0px;
  background-color: #fafafa;
  color: #004545;
}

.mat-title2{
  min-height: 0px !important;
  text-transform: uppercase;
  font-weight: bold;
  min-width: 90%;
  font-size: 16px;
  margin: 0px 3px 0px 0px;
  color: #004545;
}

.header-tf{
  background-color: white !important;
}

.dettaglio .mat-expansion-panel-header.mat-expanded {
  background-color: white !important;
 }

.mat-expansion-panel-header{
   background-color: #fafafa;
 }

 .mat-expansion-panel-header.mat-expanded {
  background-color: #fafafa !important;
 }

 .mat-expansion-panel-header:hover {
  background-color: #fafafa !important;
 }
.mat-button{
  float: right;

}

.delete-button{
  width: 0%; 
}

.form-campo{
  width: 40%;
  padding: 5px;
}

.background {
  background-color: #fafafa;
}

::ng-deep .activity-element {
  margin: 0px;
  flex: 1;
  position: absolute;
  top: 0px;
  bottom: 0px;
  right: 0px;
  left: 0px;
  background-color: #fafafa;
}

.textarea{
  height: 20px;
  font-weight: bold;
}

.textareaForm{
  padding-left: 5px !important;
  width: -webkit-fill-available;
}


.mask {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 100%;
  z-index: 500;
  background-color: rgba(0,0,0,0.7)
}
.lds-roller {
  top:50%;
  left:50%;
  display: inline-block;
  position: fixed;
  width: 64px;
  height: 64px;
}
.lds-roller div {
  animation: lds-roller 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
  transform-origin: 32px 32px;
  
}
.lds-roller div:after {
  content: " ";
  display: block;
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #ffff;
  margin: -3px 0 0 -3px;
  z-index: 10;
}
.lds-roller div:nth-child(1) {
  animation-delay: -0.036s;
}
.lds-roller div:nth-child(1):after {
  top: 50px;
  left: 50px;
}
.lds-roller div:nth-child(2) {
  animation-delay: -0.072s;
}
.lds-roller div:nth-child(2):after {
  top: 54px;
  left: 45px;
}
.lds-roller div:nth-child(3) {
  animation-delay: -0.108s;
}
.lds-roller div:nth-child(3):after {
  top: 57px;
  left: 39px;
}
.lds-roller div:nth-child(4) {
  animation-delay: -0.144s;
}
.lds-roller div:nth-child(4):after {
  top: 58px;
  left: 32px;
}
.lds-roller div:nth-child(5) {
  animation-delay: -0.18s;
}
.lds-roller div:nth-child(5):after {
  top: 57px;
  left: 25px;
}
.lds-roller div:nth-child(6) {
  animation-delay: -0.216s;
}
.lds-roller div:nth-child(6):after {
  top: 54px;
  left: 19px;
}
.lds-roller div:nth-child(7) {
  animation-delay: -0.252s;
}
.lds-roller div:nth-child(7):after {
  top: 50px;
  left: 14px;
}
.lds-roller div:nth-child(8) {
  animation-delay: -0.288s;
}
.lds-roller div:nth-child(8):after {
  top: 45px;
  left: 10px;
}
@keyframes lds-roller {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}