  retrieveConfig(section: any){
    this.flowConfigurationService.searchTabgenFields(this.fmflow.name + "_SCARTI_REGIONE").then(response => {
        if (response.success) {
            if (response.opTargetObject.error) {
            } else {
                for(let i=0; i<response.opTargetObject.items.length; i++){
                    if(response.opTargetObject.items[i].description == "CAMPO_CHIAVE"){
                        var campoChiave = response.opTargetObject.items[i].tabgenValueColumn;
                    }
                    if(response.opTargetObject.items[i].description == "NOME_CAMPO"){
                      var nomecampo = response.opTargetObject.items[i].tabgenValueColumn;
                  }
                }
                let filterGlob: SearchFilters = new SearchFilters();
                filterGlob.tabgenId = this.fmflow.name + "_SCARTI_REGIONE";
                this.flowConfigurationService.tabgenValueListSearchDataProvider(filterGlob).then(response => {
                    if (response.success) {
                        if (response.opTargetObject.error) {
                        } else {
                            for(let i=0; i<response.opTargetObject.items.length; i++){
                                if(response.opTargetObject.items[i][campoChiave.toLowerCase()] == "1"){
                                    let nomeCampo = response.opTargetObject.items[i][nomecampo.toLowerCase()];
                                    this.campiConfig.push(nomeCampo.toLowerCase());
                                }
                            }
                            for(let j=0; j<this.campiConfig.length; j++){
                                this.filterError.pkNameList.push(this.campiConfig[j]);
                                this.filterError.pkList.push(section[this.campiConfig[j]]);
                                // this.valoriConfig.push(section[this.campiConfig[j]]);
                            }
                            let extractionId = null;
                            if(this.filterFlow) {
                              extractionId = this.filterFlow.importId;
                            }
                            this.flowConfigurationService.getReturns(this.filterError,extractionId)
                            .then(result => {
                                if (result.success) {
                                  this.mapReturns = result.opTargetObject;
                                  this.lenghtReturns = this.mapReturns["values"].length;
                                    if(this.lenghtReturns== 0){
                                        this.showLoadingIndicator = false;
                                        this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                                        this.blockRightReg = true;
                                        this.firstResultDisplayReg = 0;
                                        this.countReturns = 0;
                                        this.displayedColumnsReturns = this.generaColonneReturns();
                                      }else{
                                        this.displayedColumnsReturns = this.generaColonneReturns();
                                        this.dataSourceReturns = new MatTableDataSource<any>(this.generateDatasourceReturns());
                                      }
                                } else {
                                  this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                                }
                            })
                            .catch(e => {
                              this.activityManager.engApplication.notifyMessage('Nessun dato trovato');
                            }
                          );
                        }
                    }
                }).catch(() => {
                    this.showLoadingIndicator = false;
                    let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
                    this.activityManager.engApplication.notifyMessage(errorMessage);
                });
            }
        }
    }).catch(() => {
        let errorMessage: string = this.activityManager.engApplication.i18nInstant('UNEXPECTED_ERR');
        this.activityManager.engApplication.notifyMessage(errorMessage);
    });
}

  generaColonneReturns(): string[] {
    let colonne: string[] = [];
    let lenght = this.mapReturns["columns"].length;
    for(let i=0; i< lenght; i++){
      colonne.push(this.mapReturns["columns"][i]);
    }
    return (colonne);
  }
  
  generateDatasourceReturns():Array<any>{
    let data = new Array();
    let columnValue = null;
    let lenght = this.mapReturns["values"].length;
    for(let z = 0; z < lenght; z++){
      data[z] = {};
      let lengthColumn = this.mapReturns["columns"].length;
      for(let i = 0; i < lengthColumn; i++){
        let columnName = this.displayedColumnsReturns[i];
        columnValue = this.mapReturns["values"][z][columnName];
        data[z][columnName] = columnValue;
      }
    }
    this.blockLeftReg = true;
    this.firstResultDisplayReg = 1;
    if(lenght <= 5){
      this.countReturns = lenght;
      this.blockRightReg = true;
    }else{
      this.countReturns = 5;
      this.blockRightReg = false;
      this.dataAppReturns = new Array();
      this.dataAppReturns = data;
      data = data.slice(0,5);
  }
    return data;
  }

  searchFromPatient(element){
    let colonne = Object.keys(element);
    this.filtered = true;
    for(let i=0; i<colonne.length; i++){
      let field = colonne[i].replace(/\s/g, "");
      this.filterFlow.fkFields.push(field);
      this.filterFlow.fkValues.push((element[colonne[i]]).toUpperCase());
      // this.filterFlow.param.push((element[colonne[i]]).toUpperCase());
      let filterFlowField: FilterFlowField = new FilterFlowField();
      filterFlowField.name = field;
      filterFlowField.section = "0";
      filterFlowField.param = (element[colonne[i]]).toUpperCase();
      this.filterFlow.field.push(filterFlowField);
    }
    this.ricercaConf();

  }

  isEditModeEdit(){
    let starterParams: any = this.activity.startingParams;
    if(starterParams.extra){
      return false;
    }
  }

  sortData(event,index){
    this.filterFlow.sortField = event.active;
    this.filterFlow.sortDir = event.direction;
    this.filterFlow.sortSez = index;
    this.ricercaConf();
  }

  goToLastPage(){
    if(this.countPratiche==undefined){
      this.showLoadingIndicator = true;
      let lenght = undefined;
      let lastPage = true;
      this.contaPratiche(lenght,lastPage);
    }else{
      let mod = this.countPratiche % 10;
      if(mod != 0){
        this.filterFlow.firstResult = this.countPratiche - mod;
      }else{
        this.filterFlow.firstResult = this.countPratiche - this.filterFlow.maxResult;
      }
      this.endPage = this.countPratiche;
      this.firstResultDisplay = this.filterFlow.firstResult + 1;
      this.ricercaConf();
    }
  }

  goToFirstPage(){
    if(!this.blockLeft){
      this.showLoadingIndicator = true;
      this.filterFlow.firstResult = 0;
      this.filterFlow.maxResult = 10;
      if(this.totalItems<=this.filterFlow.maxResult){
        this.endPage = this.totalItems;
      }else{
        this.endPage = this.filterFlow.maxResult
      }
      this.firstResultDisplay = this.filterFlow.firstResult + 1;
      this.ricercaConf();
    }
  }

}
