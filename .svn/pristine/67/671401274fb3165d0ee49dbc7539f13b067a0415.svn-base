<div class="flow-extract-field">
    <div class="filtri">
         <!-- <mat-form-field>
            <mat-label>ID Estrazione</mat-label>
            <input (keydown.enter)="startSearch()" [(ngModel)]="extraction_id" matInput placeholder="ID Estrazione" />
        </mat-form-field> -->
        <mat-form-field>
            <mat-label>Flussi</mat-label>
            <mat-select [(ngModel)]="flow">
                <mat-option value=""></mat-option>
                <mat-option (onSelectionChange)="setLastVersion(flow.id);" *ngFor="let flow of flows" [value]=flow.id>
                    {{flow.name}}
                </mat-option>
            </mat-select>
        </mat-form-field>
        <mat-form-field>
            <mat-label>Versioni</mat-label>
            <mat-select [(ngModel)]="version">
                <mat-option value=""></mat-option>
                <mat-option *ngFor="let version of versions" [value]=version.id>
                    {{version.name}}
                </mat-option>
            </mat-select>
        </mat-form-field>
        <mat-form-field>
            <mat-label>Stato</mat-label>
            <mat-select [(ngModel)]="status">
                <mat-option value=""></mat-option>
                <mat-option *ngFor="let status of statuss" [value]=status>
                    {{status}}
                </mat-option>
            </mat-select>
        </mat-form-field>
        <mat-form-field class="filter">
            <input [(ngModel)]="creationDate"
                   [matDatepicker]="picker1"
                   matInput placeholder="Data Richiesta">
            <mat-datepicker-toggle [for]="picker1" matSuffix></mat-datepicker-toggle>
            <mat-datepicker #picker1></mat-datepicker>
        </mat-form-field>
        <mat-form-field class="filter">
            <input [(ngModel)]="validationDate"
                   [matDatepicker]="picker2"
                   matInput placeholder="Data Validazione">
            <mat-datepicker-toggle [for]="picker2" matSuffix></mat-datepicker-toggle>
            <mat-datepicker #picker2></mat-datepicker>
        </mat-form-field>
        <button (click)="startSearch()" mat-button matTooltip="Cerca">
            <mat-icon>search</mat-icon>
        </button>
        <button mat-button (click)="resetSearch()" matTooltip="Resetta filtri">
            <mat-icon>delete_sweep</mat-icon>
        </button>
    </div>

<div class="example-container">
    <div class="flowviewreps">
        <table #table (matSortChange)="sortData($event)" [dataSource]="dataSource" mat-table
            matSort>
            <ng-container matColumnDef="select">
                <th mat-header-cell *matHeaderCellDef sticky>
                    <mat-checkbox (change)="$event ? masterToggle() : null"
                        [checked]="selection.hasValue() && isAllSelected()"
                        [indeterminate]="selection.hasValue() && !isAllSelected()">
                    </mat-checkbox>
                </th>
                <td mat-cell *matCellDef="let row" (click)="$event.stopPropagation()">
                    <mat-checkbox (click)="$event.stopPropagation()" (change)="$event ? selection.toggle(row) : null"
                        [checked]="selection.isSelected(row)" [disabled]="row.consolidata || (row.status === 'IN_CORSO')">
                    </mat-checkbox>
                </td>
            </ng-container>

            <ng-container matColumnDef="flow">
                <th *matHeaderCellDef mat-header-cell sticky mat-sort-header> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Flusso</th>
                <td *matCellDef="let element" mat-cell> {{element.flow.name}} </td>
            </ng-container>

            <ng-container matColumnDef="version">
                <th *matHeaderCellDef mat-header-cell sticky mat-sort-header> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Versione</th>
                <td *matCellDef="let element" mat-cell> {{element.version.description}} </td>
            </ng-container>

            <ng-container matColumnDef="username">
                <th *matHeaderCellDef mat-header-cell sticky mat-sort-header> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Utente</th>
                <td *matCellDef="let element" mat-cell> {{element.username}}</td>
            </ng-container>

            <ng-container matColumnDef="creationDate">
                <th *matHeaderCellDef mat-header-cell sticky mat-sort-header> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Data Richiesta</th>
                <td *matCellDef="let element" mat-cell> {{convertData(element.creationDate)}}</td>
            </ng-container>

            <ng-container matColumnDef="validationDate">
                <th *matHeaderCellDef mat-header-cell sticky mat-sort-header> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Data Validazione</th>
                <td *matCellDef="let element" mat-cell> {{convertData(element.validationDate)}}</td>
            </ng-container>

            <ng-container matColumnDef="status">
                <th *matHeaderCellDef mat-header-cell sticky mat-sort-header> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Stato Richiesta</th>
                <td *matCellDef="let element" mat-cell>
                    <mat-icon (click)="$event.stopPropagation();showErrorDetails(element)"
                        [ngClass]="{'termiantako':element.status === 'INCOMPLETE'}"
                        matTooltip="{{statusTooltip(element.status)}}">{{statusIcon(element.status)}}</mat-icon>
                    <div *ngIf="element.status === 'INCOMPLETE'" class="number-circle"
                        (click)="$event.stopPropagation();showErrorDetails(element)">
                        {{errorDetails(element.errors)}}
                    </div>
                </td>
            </ng-container>


            <ng-container matColumnDef="download">
                <th *matHeaderCellDef mat-header-cell sticky> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Download</th>
                <td *matCellDef="let element" mat-cell>
                    <button (click)="$event.stopPropagation()"
                        [matMenuTriggerFor]="menu"
                        aria-label="Example icon-button with a menu" mat-icon-button>
                        <mat-icon>cloud_download</mat-icon>
                    </button>
                    <mat-menu #menu="matMenu">

                        <button (click)="downloadLOG(element)" [disabled]="element.status != 'NOT_WELL_FORMED'" mat-menu-item>
                            <mat-icon>list</mat-icon>
                            <span>Download Errors</span>
                        </button>
                        <button (click)="downloadFiles(element)" mat-menu-item>
                            <mat-icon>list</mat-icon>
                            <span>Download File</span>
                        </button>
                    </mat-menu>
            </ng-container>

            <ng-container matColumnDef="validation">
                <th *matHeaderCellDef mat-header-cell sticky> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Validazione</th>
                <td *matCellDef="let element" mat-cell>
                    <button (click)="$event.stopPropagation();validation(element)" matTooltip="Avvia validazione" mat-button>
                        <mat-icon>spellcheck</mat-icon>
                    </button>
            </ng-container>

            <ng-container matColumnDef="flowview">
                <th *matHeaderCellDef mat-header-cell sticky> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Visualizza dati</th>
                <td *matCellDef="let element" mat-cell>
                    <button (click)="$event.stopPropagation();goViewActivity(element)" matTooltip="Visualizza dati" 
                        [disabled]="element.status != 'VALIDATED'"
                        mat-button>
                        <mat-icon>list</mat-icon>
                    </button>
            </ng-container>


            <tr *matHeaderRowDef="displayedColumns; sticky: true" mat-header-row></tr>
            <tr (click)="goEditActivity(row)" *matRowDef="let row; columns: displayedColumns;" mat-row></tr>
        </table>
    </div>
</div>
    <mat-paginator #paginator
            (page)="getServerData($event)" [length]="totalItems" [pageSizeOptions]="[5, 10, 25, 100]"
        [pageSize]="10">
    </mat-paginator>

</div>

<div *ngIf="showLoadingIndicator" class="mask">
    <div *ngIf="showLoadingIndicator" class="lds-roller">
        <div></div>
        <div></div>
        <div></div>
        <div></div>
        <div></div>
        <div></div>
        <div></div>
        <div></div>
    </div>
</div>
