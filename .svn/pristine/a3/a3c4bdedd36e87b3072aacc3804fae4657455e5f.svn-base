export class FlowOutputSearchActivityComponent extends EditActivityComponent {
    filterGlob: SearchFilters = new SearchFilters();
    totalItems: number;
    blockLeft: boolean = true;
    blockRight: boolean;
    pageIndexStore: number = 1;
