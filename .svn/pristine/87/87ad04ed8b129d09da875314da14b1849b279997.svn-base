.example-card {
  box-shadow: 2px 6px 9px 3px rgba(200, 200, 200, 1);
  -webkit-box-shadow: 2px 3px 9px 3px rgba(200, 200, 200, 1);
  -moz-box-shadow: 2px 3px 9px 3px rgba(200, 200, 200, 1);
  padding: 10px;
  margin: 8px;
  margin-left: 10px;
  margin-top: 10px;
  font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 1rem;
  font-weight: 400;
  line-height: 1.5;
  color: #292b2c;
  border: 1px;
  padding-bottom: 50px;
}

